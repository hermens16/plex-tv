<MediaContainer offset="0" totalSize="8" identifier="tv.plex.provider.epg" size="8"><Video guid="plex://episode/69d79c1fe61f3ea47c1c9561" key="/library/metadata/69d79c1fe61f3ea47c1c9561" ratingKey="69d79c1fe61f3ea47c1c9561" summary="Ezequiel sente-se traído e entrega a sua filha ao infame Celso, que tenciona abusar dela. Sebastiăo salva-a do incidente. Camila, triste, continua com seu plano de destruir a vida de sua madrinha Elda e conta a Ezequiel o motivo que a levou a fazer isso: a traiçăo de sua măe, acusando-a injustamente." type="episode" contentRating="NONADULT" duration="3057000" grandparentArt="https://d3dpwvkv1y8pcn.cloudfront.net/Images/S3/WAPIS/272_1672724.jpg" grandparentGuid="plex://show/687fff08c082969749e5c0d6" grandparentKey="/library/metadata/687fff08c082969749e5c0d6" grandparentRatingKey="687fff08c082969749e5c0d6" grandparentThumb="https://d3dpwvkv1y8pcn.cloudfront.net/Images/S3/WAPIS/wedotv_amor_piel_salvaje20630_1672565-portrait.jpg" grandparentTitle="Piel Salvaje" grandparentType="show" index="97" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://d3dpwvkv1y8pcn.cloudfront.net/Images/S3/WAPIS/272_1672724.jpg" title="S01E097" userState="0"><Image alt="S01E097" type="coverArt" url="https://d3dpwvkv1y8pcn.cloudfront.net/Images/S3/WAPIS/272_1672724.jpg"/><Image alt="S01E097" type="coverPoster" url="https://d3dpwvkv1y8pcn.cloudfront.net/Images/S3/WAPIS/wedotv_amor_piel_salvaje20630_1672565-portrait.jpg"/><Image alt="S01E097" type="snapshot" url="https://d3dpwvkv1y8pcn.cloudfront.net/Images/S3/WAPIS/272_1672724.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1776902181" duration="3057000" endsAt="1776905238" id="69df8542ec0d2bce0f457cd0" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid