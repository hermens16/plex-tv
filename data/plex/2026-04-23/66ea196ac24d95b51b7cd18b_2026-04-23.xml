<MediaContainer offset="0" totalSize="13" identifier="tv.plex.provider.epg" size="13"><Video guid="plex://episode/69dce3c3b195a559c401f511" key="/library/metadata/69dce3c3b195a559c401f511" ratingKey="69dce3c3b195a559c401f511" summary="Camila explica a Ezequiel y Julia el motivo de su felicidad: se casará con Max, y también pronto se reunirá con su madre. Por medio de Luciano, Rosa le envía la dirección donde van a encontrarse, pero Elda, rabiosa, copia los datos y los revela al Inspector Torrealba que ordena un operativo policial para detenerla." type="episode" contentRating="NONADULT" duration="3144000" grandparentArt="https://cdn-images.watch4.com/1080/3/1672724.jpg" grandparentGuid="plex://show/66ea19708651b52ba9cee047" grandparentKey="/library/metadata/66ea19708651b52ba9cee047" grandparentRatingKey="66ea19708651b52ba9cee047" grandparentThumb="https://cdn-images.watch4.com/1920/2/1672724.jpg" grandparentTitle="Piel Salvaje" grandparentType="show" index="54" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1672724.jpg" title="S01:E54" userState="0"><Image alt="S01:E54" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1672724.jpg"/><Image alt="S01:E54" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1672724.jpg"/><Image alt="S01:E54" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1672724.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1776914628" duration="3145000" endsAt="1776917773" id="69df86115f893407da129ffa" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69de347e275a3c28e0c9c47b" key="/library/metadata/69de347e275a3c28e0c9c47b" ratingKey="69de347e275a3c28e0c9c47b" summary="Victoria promete a Builder hacer lo que él quiera para que la perdone; él le pide un beso que le diga que ella sabe que la ama y nunca sería capaz de hacerle dańo. Florencia despierta feliz porque pasó la noche haciendo el amor con Nicolás; quien, sin embargo, está algo triste porque ese día es el entierro de su tío y ni siquiera un momento ha dejado de pensar en Victoria. Hilario aclara a Fernanda y Nicolás que su hija y él están ahí para firmar los papeles del traspaso de las tierras que les va a devolver; el seńor Guanipa insta a la seńora Alcoy a dejar claro si con ese trato va a comenzar la paz entre ambas familias. Felipe asegura a Clementina que es con ella con quien quiere tener una historia de amor; la muchacha lo rechaza luego de mencionar que Antonieta contestó una de sus llamadas y trató de humillarla con sus comentarios.Victoria, a gritos, le exige a Florencia que se vaya de su casa cuando aparecen Adelaida e Hilario a ver qué ocurre; ambos se sorprenden al ver ahí a la joven Zapata." type="episode" contentRating="NONADULT" duration="3040000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="55" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E055" userState="0"><Image alt="S01:E055" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E055" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E055" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe