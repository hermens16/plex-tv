<MediaContainer offset="0" totalSize="13" identifier="tv.plex.provider.epg" size="13"><Video guid="plex://episode/69c6794574f31a68d329c81a" key="/library/metadata/69c6794574f31a68d329c81a" ratingKey="69c6794574f31a68d329c81a" summary="Negado a aceptar la decisión de Victoria de alejarse de él ahora que será padre del hijo que espera Florencia; Nicolás trata de convencer a su amada de confiar en que es posible estar juntos. Florencia se presenta en casa de Victoria para saber si ésta es capaz de seguir junto a Nicolás a pesar de su estado; una vez que Nicolás llega al lugar, Florencia se impone en defensa de su amor por el padre de su hijo.Ante el desánimo que embarga a Victoria, Hilario se desahoga con Adelaida, pues teme no poder proteger a su hija del sufrimiento que le causa la noticia del embarazo de Florencia;" type="episode" contentRating="NONADULT" duration="2887000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="118" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E118" userState="0"><Image alt="S01:E118" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E118" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E118" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1775349499" duration="3021000" endsAt="1775352520" id="69c873