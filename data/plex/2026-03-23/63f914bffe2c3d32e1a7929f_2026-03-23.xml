itees or had qualified via previous events." type="episode" contentRating="PG-13" duration="5113000" grandparentArt="https://provider-static.plex.tv/epg/cms/production/edf668f1-c23a-45da-af5f-0867b5e26a77/GLORYs4.jpg" grandparentGuid="plex://show/69b9f1686a5a74619082ec74" grandparentKey="/library/metadata/69b9f1686a5a74619082ec74" grandparentRatingKey="69b9f1686a5a74619082ec74" grandparentThumb="https://provider-static.plex.tv/epg/cms/production/e82ff7c4-015e-440d-a8df-d960efc5d3f8/GLORY_2000x3000_Nicholas_Olsen.jpg" grandparentTitle="K1" grandparentType="show" index="46" originallyAvailableAt="2003-10-11T00:00:00Z" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://partner-upload-assets.wurl.com/glory_kickboxing/WGP03ELIM.jpg" title="K1 World Grand Prix: Final 14, Osaka, 2003" userState="0" year="2003"><Image alt="K1 World Grand Prix: Final 14, Osaka, 2003" type="coverArt" url="https://provider-static.plex.tv/epg/cms/production/edf668f1-c23a-45da-af5f-0867b5e26a77/GLORYs4.jpg"/><Image alt="K1 World Grand Prix: Final 14, Osaka, 2003" type="coverPoster" url="https://provider-static.plex.tv/epg/cms/production/e82ff7c4-015e-440d-a8df-d960efc5d3f8/GLORY_2000x3000_Nicholas_Olsen.jpg"/><Image alt="K1 World Grand Prix: Final 14, Osaka, 2003" type="snapshot" url="https://partner-upload-assets.wurl.com/glory_kickboxing/WGP03ELIM.jpg"/><Genre filter="genre=620143f98578b9238e1cdb8a" id="620143f98578b9238e1cdb8a" key="/library/sections/home/all?genre=620143f98578b9238e1cdb8a" ratingKey="genre_620143f98578b9238e1cdb8a" slug="sports" tag="Sports" type="directory" context="tag.genre"/><Media beginsAt="1774260138" duration="5113000" endsAt="1774265251" id="69b9f2946a5a74619082f991" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774296631" duration="5113000" endsAt="1774301744" id="69b9f2946a5a74619082f994" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69b9f1686a5a74619082ec76" key="/