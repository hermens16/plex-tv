x://episode/69cd10913d7cb988a23b3909" key="/library/metadata/69cd10913d7cb988a23b3909" ratingKey="69cd10913d7cb988a23b3909" summary="Max y Camila en idílicos momentos sin importar ní el resultado del A.D.N. Continúan en la búsqueda de Rosa Blanco. Dos encomiendas entregadas por un mensajero, una para los López Méndez y otra para los Aragón, confirman la reaparición de El Doliente." type="episode" contentRating="NONADULT" duration="2858000" grandparentArt="https://cdn-images.watch4.com/1080/3/1672724.jpg" grandparentGuid="plex://show/66ea19708651b52ba9cee047" grandparentKey="/library/metadata/66ea19708651b52ba9cee047" grandparentRatingKey="66ea19708651b52ba9cee047" grandparentThumb="https://cdn-images.watch4.com/1920/2/1672724.jpg" grandparentTitle="Piel Salvaje" grandparentType="show" index="41" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1672724.jpg" title="S01:E41" userState="0"><Image alt="S01:E41" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1672724.jpg"/><Image alt="S01:E41" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1672724.jpg"/><Image alt="S01:E41" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1672724.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1775710622" duration="3785000" endsAt="1775714407" id="69cd10923d7cb988a23b392d" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1775732292" duration="2992000" endsAt="1775735284" id="69cf0b172ff4bb4e6904073c" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1775762909" duration="2858000" endsAt="1775765767" id="69cf0b172ff4bb4e69040746" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69cd10923d7cb988a23b390a" key="/library/metadata/69cd10923d7cb988a23b390a" ratingKey="69cd10923d7cb988a23b390a" summary="Un incrédulo Nicolás trata de entender cómo Victoria pudo arremeter violentamente en contra de Florencia a sabiendas de su embarazo, pues ahora Florencia llora la pérdida de su hijo. En un nuevo día, Nicolás se enfrenta a Victoria, a quien le reprocha haber causado la muerte de su hijo al golpear a Florencia; por más que Victoria trata de convencerlo de que todo es un invento de su esposa; Nicolás está seguro de la culpabilidad de Guanipa. Segura de que todas las pruebas pueden inculpar a Sergio de la muerte de Genara, Fernanda insiste en amenazarlo con acusarlo a la policía si éste no la ayuda a arrebatarle la hacienda Cantarrana a la familia Guanipa, así deba traicionar a Victoria; Sergio no tiene otra salida que aceptar el ofrecimiento de Fernanda. Una vez que Florencia se refugia en Fernanda temerosa de que Nicolás descubra que ella es quien miente sobre la pérdida de su hijo; Eugenia ha escuchado a su madre, a quien le asegura irse junto a su padre apenas éste consiga un lugar donde vivir." type="episode" contentRating="NONADULT" duration="2505000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="123" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E123" userState="0"><Image alt="S01:E123" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E123" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E123" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc1861