b9ddb0e" ratingKey="69af66c0406f1a2e7b9ddb0e" summary="Lynn y Jason Ryder compran un histórico restaurante en Connecticut, pero son invadidos por las fuerzas del mal y empleados y clientes son atacados. Investigadores, médiums y clarividentes son llamados para librar al restaurante de su pasado demoníaco." type="movie" contentRating="PG-13" duration="2601000" originallyAvailableAt="2012-11-22T00:00:00Z" requiresConsent="1" skipParent="1" thumb="https://d31l2nn7dlh4li.cloudfront.net/amg27164/asset_artifacts/image/fetch_media/e6472f8d14e51a00/AHaunting_2000x3000_SPANISH.png" title="Historias De Ultratumba S05E08: Los Intrusos" userState="0" year="2012"><Image alt="Historias De Ultratumba S05E08: Los Intrusos" type="coverArt" url="https://d31l2nn7dlh4li.cloudfront.net/amg27164/asset_artifacts/image/fetch_media/b4589bbb4acee254/AHaunting_S05E47_TheUninvited.png"/><Image alt="Historias De Ultratumba S05E08: Los Intrusos" type="coverPoster" url="https://d31l2nn7dlh4li.cloudfront.net/amg27164/asset_artifacts/image/fetch_media/e6472f8d14e51a00/AHaunting_2000x3000_SPANISH.png"/><Genre filter="genre=6006cc18610ee2002c74f308" id="6006cc18610ee2002c74f308" key="/library/sections/home/all?genre=6006cc18610ee2002c74f308" ratingKey="genre_6006cc18610ee2002c74f308" slug="thriller" tag="Thriller" type="directory" context="tag.genre"/><Media beginsAt="1773797890" duration="2601000" endsAt="1773800491" id="69b35b3674f73c8168511877" onAir="0" premiere="1" videoResolution="720" origin="livetv"/></Video><Video art="https://d31l2nn7dlh4li.cloudfront.net/amg27164/asset_artifacts/image/fetch_media/f211ab71bd4bff86/AHaunting_1920x1080_SPANISH.png" guid="plex://movie/69af66c0406f1a2e7b9ddb0f" key="/library/metadata/69af66c0406f1a2e7b9ddb0f" ratingKey="69af66c0406f1a2e7b9ddb0f" summary="En Maryland, la casa de Kathie Sheats, una madre soltera, es acosada por un demonio. Los psíquicos, los sacerdotes y los investigadores paranormales no logran resolver el problema. Sólo la propia Kathie puede vencer a la entidad oscura... con la ayuda de un ángel." type="movie" contentRating="PG-13" duration="2612000" originallyAvailableAt="2010-02-12T00:00:00Z" requiresConsent="1" skipParent="1" thumb="https://d31l2nn7dlh4li.cloudfront.net/amg27164/asset_artifacts/image/fetch_media/776802d9e8d31e25/AHaunting_2000x3000_SPANISH.png" title="Historias De Ultratumba S05E01: Angeles Y Demonios" userState="0" year="2010"><Image alt="Historias De Ultratumba S05E01: Angeles Y Demonios" type="coverArt" url="https://d31l2nn7dlh4li.cloudfront.net/amg27164/asset_artifacts/image/fetch_media/f211ab71bd4bff86/AHaunting_1920x1080_SPANISH.png"/><Image alt="Historias De Ultratumba S05E01: Angeles Y Demonios" type="coverPoster" url="https://d31l2nn7dlh4li.cloudfront.net/amg27164/asset_artifacts/image/fetch_media/776802d9e8d31e25/AHaunting_2000x3000_SPANISH.png"/><Genre filter="genre=6006cc18610ee2002c74f308" id="6006cc18610ee2002c74f308" key="/library/sections/home/all?genre=6006cc18610ee2002c74f308" ratingKey="genre_6006cc18610ee2002c74f308" slug="thriller" tag="Thriller" type="directory" context="tag.genre"/><Media beginsAt="1773800491" duration="2612000" endsAt="1773803103" id="69b35b3674f73c8168511878" onAir="0" premiere="1" videoResolution="720" origin="livetv"/></Video><Video art="https://d31l2nn7dlh4li.cloudfront.net/amg27164/asset_artifacts/image/fetch_media/43787053d68b2dcb/AHaunting_S05E48_TheExorcismOfCindySauer.png" guid="plex://movie/69af66c0406f1a2e7b9ddb10" key="/library/metadata/69af66c0406f1a2e7b9ddb10" ratingKey="69af66c0406f1a2e7b9ddb10" summary="Cindy Sauer intenta superar la repentina muerte de su marido cuando sombras oscuras y pesadillas la convencen de que un demonio la persigue a ella y a su familia. Cindy recurre a un pastor para que exorcice al ente antes de que los vuelva literalmente locos." type="movie" contentRating="PG-13" duration="2610000" originallyAvailableAt="2012-11-29T00:00:00Z" requiresConsent="1" skipParent="1" thumb="https://d31l2nn7dlh4li.cloudfront.net/amg27164/asset_artifacts/image/fetch_media/fd7be2945edec3d7/AHaunting_2000x3000_SPANISH.png" title="Historias De Ultratumba S05E09: El Exorcismo De Cindy Sauer" userState="0" year="2012"><Image alt="Historias De Ultratumba S05E09: El Exorcismo De Cindy Sauer" type="coverArt" url="https://d31l2nn7dlh4li.cloudfront.net/amg27164/asset_artifacts/image/fetch_media/43787053d68b2dcb/AHaunting_S05E48_TheExorcismOfCindySauer.png"/><Image alt="Historias De Ultratumba S05E09: El Exorcismo De Cindy Sauer" type="coverPoster" url="https://d31l2nn7dlh4li.cloudfront.net/amg27164/asset_artifacts/image/fetch_media/fd7be2945edec3d7/AHaunting_2000x3000_SPANISH.png"/><Genre filter="genre=6006cc18610ee2002c74f308" id="6006cc18610ee2002c74f308" key="/library/sections/home/all?genre=6006cc18610ee2002c74f308" ratingKey="genre_6006cc18610ee2002c74f308" slug="thriller" tag="Thriller" type="directory" context="tag.genre"/><Media beginsAt="1773803103" duration="2610000" endsAt="1773805713" id="69b35b3674f73c8168511879" onAir="0" premiere="1" videoResolution="720" origin="livetv"/></Video><Video art="https://d31l2nn7dlh4li.cloudfront.net/amg27164/asset_artifacts/image/fetch_media/cc19b3ed268c8005/AHaunting_S04E35_GhostHunter.png" guid="plex://movie/69af66c0406f1a2e7b9ddb11" key="/library/metadata/69af66c0406f1a2e7b9ddb11" ratingKey="69af66c0406f1a2e7b9ddb11" summary="Stacy Jones ha dedicado su vida a ayudar a otros a comprender y a enfrentar las amenazas paranormales. Como la experta que es, se siente tranquila al permitir que su hijo adolescente, Jamie, se una a ella en una investigación que realizan en un cementerio cercano a su casa, ubicada en el estado de Nueva York. Pero poco después de regresar a la casa, Jamie descubre una extrańa marca de rasguńos en su pierna. Jaime también escucha ruidos inexplicables que resuenan en la casa y observa cómo algunos objetos vuelan por toda la habitación. Él sabe que ha despertado a una entidad maligna. Cuando Stacey es testigo de cómo un demonio ataca a Jamie, ella recurre a su amigo y colega John Zaffis para salvar a su hijo de una entidad que está dispuesta a poseer su alma." type="movie" contentRating="PG-13" duration="2970000" originallyAvailableAt="2007-10-12T00:00:00Z" requiresConsent="1" skipParent="1" thumb="https://d31l2nn7dlh4li.cloudfront.net/amg27164/asset_artifacts/image/fetch_media/13f0b24baa00543d/AHaunting_2000x3000_SPANISH.png" title="Historias De Ultratumba S04E09: Cazadores De Fantasmas" userState="0" year="2007"><Image alt="Historias De Ultratumba S04E09: Cazadores De Fantasmas" type="coverArt" url="https://d31l2nn7dlh4li.cloudfront.net/amg27164/asset_artifacts/image/fetch_media/cc19b3ed268c8005/AHaunting_S04E35_GhostHunter.png"/><Image alt="Historias De Ultratumba S04E09: Cazadores De Fantasmas" type="coverPoster" url="https://d31l2nn7dlh4li.cloudfront.net/amg27164/asset_artifacts/image/fetch_media/13f0b24baa00543d/AHaunting_2000x3000_SPANISH.png"/><Genre filter="genre=6006cc18610ee2002c74f308" id="6006cc18610ee2002c74f308" key="/library/sections/home/all?genre=6006cc18610ee2002c74f308" ratingKey="genre_6006cc18610ee2002c74f308" slug="thriller" tag="Thriller" type="directory" context="tag.genre"/><Media beginsAt="1773805713" duration="2970000" endsAt="1773808683" id="69b35b3674f73c816851187a" onAir="0" premiere="1" videoResolution="720" origin="livetv"/></Video><Video art="https://d31l2nn7dlh4li.cloudfront.net/amg27164/asset_artifacts/image/fetch_media/050fb295d758dfee/AHaunting_1920x1080_SPANISH.png" guid="plex://movie/69af66c0406f1a2e7b9ddb12" key="/library/metadata/69af66c0406f1a2e7b9ddb12" ratingKey="69af66c0406f1a2e7b9ddb12" summary="Judy McCarthy tiene grandes esperanzas para su familia en su nuevo hogar. Pero poco después de que se mudan, una presencia siniestra se manifiesta desde los rincones sombríos de su hogar en el estado de Texas. Al pasar del tiempo, esa presencia concentra su ira en la hermosa hija adolescente de los McCarthy, Caressa. Comienza a atormentarla cada noche en el lugar de la casa donde debería sentirse más segura: en los confines de su propia habitación. A medida que van transcurriendo las noches, el fantasma se torna aún más fuerte y está más resuelto a mantener cautiva a Caressa. Mientras Judy lucha por proteger a sus seres queridos, ella devela un secreto violento que amenaza a todos aquellos a quienes ama." type="movie" contentRating="PG-13" duration="2970000" originallyAvailableAt="2007-10-19T00:00:00Z" requiresConsent="1" skipParent="1" thumb="https://d31l2nn7dlh4li.cloudfront.net/amg27164/asset_artifacts/image/fetch_media/84d7b9d402b5f42d/AHaunting_2000x3000_SPANISH.png" title="Historias De Ultratumba S04E10: Perseguidos Por El Mal" userState="0" year="2007"><Image alt="Historias De Ultratumba S04E10: Perseguidos Por El Mal" type="coverArt" url="https://d31l2nn7dlh4li.cloudfront.net/amg27164/asset_artifacts/image/fetch_media/050fb295d758dfee/AHaunting_1920x1080_SPANISH.png"/><Image alt="Historias De Ultratumba S04E10: Perseguidos Por El Mal" type="coverPoster" url="https://d31l2nn7dlh4li.cloudfront.net/amg27164/asset_artifacts/image/fetch_media/84d7b9d402b5f42d/AHaunting_2000x3000_SPANISH.png"/><Genre filter="genre=6006cc18610ee2002c74f308" id="6006cc18610ee2002c74f308" key="/library/sections/home/all?genre=6006cc18610ee2002c74f308" ratingKey="genre_6006cc18610ee2002c74f308" slug="thriller" tag="Thriller" type="directory" context="tag.genre"/><Media beginsAt="1773808683" duration="2970000" endsAt="1773811653" id="69b35b3674f73c816851187b" onAir="0" premiere="1" videoResolution="720" origin="livetv"/></Video><Video art="https://d31l2nn7dlh4li.cloudfront.net/amg27164/asset_artifacts/image/fetch_media/a69752d26aaa6c66/AHaunting_S04E37_CasaDeLosMuertos.png" guid="plex://movie/69af66c0406f1a2e7b9ddb13" key="/library/metadata/69af66c0406f1a2e7b9ddb13" ratingKey="69af66c0406f1a2e7b9ddb13" summary="El guitarrista de jazz latino Eddie Benitez se muda con su familia a la localidad de Tempe, estado de Arizona, con la esperanza de poder revivir su carrera musical. Pero su optimismo se desvanece cuando ciertos eventos inexplicables comienzan a abrumar la casa, a la vez que su hijo cae gravemente enfermo. Los médicos no son capaces de diagnosticar la misteriosa dolencia que lo aqueja y Eddie comienza a pensar que una entidad sobrenatural podría ser la culpable del problema. Cuando procede a indagar un poco más en la historia de la casa, descubre que la habitación donde se encuentra su hijo fue el escenario de un suicidio espantoso. Eddie teme que el espíritu de un hombre fallecido hace tiempo le esté causando la enfermedad a su hijo, matándolo en muy lentamente. Al ver que la vida de su propio hijo está en juego, Eddie recurre a sus raíces puertorriqueńas para combatir al mortífero fantasma y, de esa forma, intentar salvar a su familia." type="movie" contentRating="PG-13" duration="2970000" originallyAvailableAt="2007-10-26T00:00:00Z" requiresConsent="1" skipParent="1" thumb="https://d31l2nn7dlh4li.cloudfront.net/amg27164/asset_artifacts/image/fetch_media/3da4f777ec1f1c5c/AHaunting_2000x3000_SPANISH.png" title="Historias De Ultratumba S04E11: La Casa De Los Muertos" userState="0" year="2007"><Image alt="Historias De Ultratumba S04E11: La Casa De Los Muertos" type="coverArt" url="https://d31l2nn7dlh4li.cloudfront.net/amg27164/asset_artifacts/image/fetch_media/a69752d26aaa6c66/AHaunting_S04E37_CasaDeLosMuertos.png"/><Image alt="Historias De Ultratumba S04E11: La Casa De Los Muertos" type="coverPoster" url="https://d31l2nn7dlh4li.cloudfront.net/amg27164/asset_artifacts/image/fetch_media/3da4f777ec1f1c5c/AHaunting_2000x3000_SPANISH.png"/><Genre filter="genre=6006cc18610ee2002c74f308" id="6006cc18610ee2002c74f308" key="/library/sections/home/all?genre=6006cc18610ee2002c74f308" ratingKey="genre_6006cc18610ee2002c74f308" slug="thriller" tag="Thriller" type="directory" context="tag.genre"/><Media beginsAt="1773789718" duration="2971000" endsAt="1773792689" id="69b35b3674f73c8168511874" onAir="0" premiere="1" videoResolution="720" origin="livetv"/><Media beginsAt="1773811653" duration="2970000" endsAt="1773814623" id="69b35b3674f73c816851187c" onAir="0" premiere="1" videoResolution="720" origin="livetv"/></Video></MediaContainer>
