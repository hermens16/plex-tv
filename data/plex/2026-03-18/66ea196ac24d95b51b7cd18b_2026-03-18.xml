tingKey="69b0b83aba3a6d319e0e710b" grandparentThumb="https://cdn-images.watch4.com/1920/2/1672730.jpg" grandparentTitle="Te Tengo en Salsa" grandparentType="show" index="1" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1672730.jpg" title="S01:E01" userState="0"><Image alt="S01:E01" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1672730.jpg"/><Image alt="S01:E01" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1672730.jpg"/><Image alt="S01:E01" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1672730.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1773804322" duration="3272000" endsAt="1773807594" id="69b0b83aba3a6d319e0e7126" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1773825525" duration="3198000" endsAt="1773828723" id="69b1611bb6ba59737061bad9" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1773856140" duration="3332000" endsAt="1773859472" id="69b1611bb6ba59737061bae3" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69b16118b6ba59737061bac9" key="/library/metadata/69b16118b6ba59737061bac9" ratingKey="69b16118b6ba59737061bac9" summary="Alberto pide protección policial para su casa y su familia; Omar llega a la conclusión de que Claudio sí está involucrado en la muerte de su hermano - Patricia no entiende por qué Gertrudis insiste en condenar a su hija a una relación con un troglodita como Pablo - Alberto le cuenta a su madre el encuentro que tuvo con el sicario que mató a su papá; Gertrudis finge ira y sorpresa, llamando de inmediato a Claudio para alertarlo sobre la situación" type="episode" contentRating="NONADULT" duration="3187000" grandparentArt="https://cdn-images.watch4.com/1080/3/1673084.jpg" grandparentGuid="plex://show/68bad9a39aa661c3574d4960" grandparentKey="/library/metadata/68bad9a39aa661c3574d4960" grandparentRatingKey="68bad9a39aa661c3574d4960" grandparentThumb="https://cdn-images.watch4.com/1920/2/1673084.jpg" grandparentTitle="Corazon Traicionado" grandparentType="show" index="38" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1673084.jpg" title="Corazón Traicionado - S01:E38" userState="0"><Image alt="Corazón Traicionado - S01:E38" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E38" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E38" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1773816798" duration="3187000" endsAt="1773819985" id="69b1611bb6ba59737061bad6" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1773846958" duration="3187000" endsAt="1773850145" id="69b1611bb6ba59737061bae0" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1773877975" duration="3188000" endsAt="1773881163" id="69b1611bb6ba59737061baea" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69b16119b6ba59737061baca" key="/library/metadata/69b16119b6ba59737061baca" ratingKey="69b16119b6ba59737061baca" summary="Tras descubrir a Nicolás besando a Florencia, Victoria le reprocha a su amado el dejarse manipular por su esposa, quien se escuda detrás de la memoria de su padre para dar lástima. Por más que Nicolás se niega a creer que Victoria sea capaz de asesinar a un caballo, Florencia lo convence de que su amada Guanipa es capaz de todo por recuperar su amor; en ese momento, dos peones de la hacienda le informan a la pareja que la casa del difunto Rosendo Zapata está en llamas. A Cantarrana llega un enfurecido Nicolás en busca de una explicación sobre lo sucedido, a lo que Victoria –sin dejarlo hablar- asegura haber sido ella la culpable. Caída la noche, Victoria le reclama a su padre el haber asesinado a General y el haberlo marcado con el hierro de ella para que la inculparan, pero Hilario le asegura que él no es culpable de esa muerte; Victoria está dispuesta a esclarecer el asunto. En un nuevo día, Florencia se encuentra con Moncho en un lugar apartado de la hacienda para entregarle una cierta cantidad de dinero por haberla ayudado a matar al caballo de su padre; Moncho está convencido de que alguien más está detrás de la idea de matar al animal." type="episode" duration="2596000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="102" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E102 - Episodio 102" userState="0"><Image alt="S01:E102 - Episodio 102" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E102 - Episodio 102" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E102 - Episodio 102" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1773822929" duration="2596000" endsAt="1773825525" id="69b1611bb6ba59737061bad8" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1773853089" duration="3051000" endsAt="1773856140" id="69b1611bb6ba59737061bae2" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69b16119b6ba59737061bacb" key="/library/metadata/69b16119b6ba59737061bacb" ratingKey="69b16119b6ba59737061bacb" summary="Una vez que Hansen los deja a solas; Hilario avisa a Adelaida que la perdona y le exige que regrese a su lado. Yosmir se molesta cuando Eugenia asegura que cree que si van a poder ser amigos, pues siente que ya perdió la oportunidad de conquistarla. Victoria le pide a Carmencita que le lea las cartas para que le dé algunas respuestas; la seńora solo llega a decirle que hay dos hombres que la rondan, que uno de ellos oculta algo y que la única manera en que va a lograr salvarse es perdonando. Hilario busca a Victoria para pedirle que lo perdone por haberla tratado mal cuando ella es lo más bonito que tiene en su vida; la joven se conmueve de ver a su papá entristecido, pero se sorprende cuando le pide que le jure, que nunca más va a ver a Nicolás Del Casal." type="episode" contentRating="NONADULT" duration="3066000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="21" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E021" userState="0"><Image alt="S01:E021" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E021" type="coverPoster" url="https://cdn-ima