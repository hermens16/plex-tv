<MediaContainer offset="0" totalSize="13" identifier="tv.plex.provider.epg" size="13"><Video guid="plex://episode/69ad6c81182d3d80391ee1da" key="/library/metadata/69ad6c81182d3d80391ee1da" ratingKey="69ad6c81182d3d80391ee1da" summary="Camila y Rosa reciben un mensaje de El Doliente encuentran al misterioso personaje que pide la escuchen el porqué de su intrigante papel, para vengarse de Ezequiel y Fausto, quienes habían estafado a su padre." type="episode" contentRating="NONADULT" duration="2979000" grandparentArt="https://cdn-images.watch4.com/1080/3/1672724.jpg" grandparentGuid="plex://show/66ea19708651b52ba9cee047" grandparentKey="/library/metadata/66ea19708651b52ba9cee047" grandparentRatingKey="66ea19708651b52ba9cee047" grandparentThumb="https://cdn-images.watch4.com/1920/2/1672724.jpg" grandparentTitle="Piel Salvaje" grandparentType="show" index="119" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1672724.jpg" title="S01:E119" userState="0"><Image alt="S01:E119" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1672724.jpg"/><Image alt="S01:E119" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1672724.jpg"/><Image alt="S01:E119" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1672724.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1773801215" duration="3107000" endsAt="1773804322" id="69b0b83aba3a6d319e0e7125" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69aebeb8fdcb297b7e2717eb" key="/library/metadata/69aebeb8fdcb297b7e2717eb" ratingKey="69aebeb8fdcb297b7e2717eb" summary="Frente a Hilario Guanipa, su hija Victoria y Genara, Felipe Osuna informa a Adelaida de Guanipa que Carlos Hansen sufrió un accidente, pero sigue con vida; el joven Osuna quiere darle a la seńora un mensaje que su jefe le envió antes de lo ocurrido, pero la mujer, aturdida, sale corriendo de su casa sin escucharlo; Hilario ordena a todos que le dejen tranquila. Sintiéndose culpable, Adelaida llora desconsolada creyendo a su amado Hansen en peligro de muerte cuando el hombre se aparece ante ella sano y salvo explicándole que todo fue una trampa que montó para distraer la vigilancia de Hilario y poder sacarla de la hacienda. Fernanda de Alcoy avisa a Florencia que ya tiene casi todo cuadrado para lo que van a hacer en contra de Victoria; Fernanda, quien se enteró de que Victoria botó a su padre de su casa, avisa a Florencia que deben aprovechar esa oportunidad para llevar a cabo su plan contra la joven Guanipa y que toda la culpa recaiga sobre Hilario; la joven seńora Del Casal le pide a su tía política le dé dos días para prepararse para el evento." type="episode" contentRating="NONADULT" duration="2944000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="100" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E100" userState="0"><Image alt="S01:E100" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E100" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E100" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1773795061" duration="3077000" endsAt="1773798138" id="69b0b83aba3a6d319e0e7123" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69aebebafdcb297b7e271833" key="/library/metadata/69aebebafdcb297b7e271833" ratingKey="69aebebafdcb297b7e271833" summary="Retendrán a Julia secuestrada hasta que Ezequiel le suplique que le devuelvan a su hija sana y salva. Camila no se dá por vencida, quiere saber quién es El Doliente y piensa que puede ser su mamá por la foto de la nińa del vestido amarillo que recibió." type="episode" contentRating="NONADULT" duration="3166000" grandparentArt="https://cdn-images.watch4.com/1080/3/1672724.jpg" grandparentGuid="plex://show/66ea19708651b52ba9cee047" grandparentKey="/library/metadata/66ea19708651b52ba9cee047" grandparentRatingKey="66ea19708651b52ba9cee047" grandparentThumb="https://cdn-images.watch4.com/1920/2/1672724.jpg" grandparentTitle="Piel Salvaje" grandparentType="show" index="18" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1672724.jpg" title="S01:E18" userState="0"><Image alt="S01:E18" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1672724.jpg"/><Image alt="S01:E18" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1672724.jpg"/><Image alt="S01:E18" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1672724.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1773807594" duration="3040000" endsAt="1773810634" id="69b0b83aba3a6d319e0e7127" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69b0b837ba3a6d319e0e7107" key="/library/metadata/69b0b837ba3a6d319e0e7107" ratingKey="69b0b837ba3a6d319e0e7107" summary="Carmen acusa a Luis y Augusto de traficar con menores. Ricardo acorralado: por un lado siente que no puede mantener una relación con cuatro mujeres a la vez, pero por el otro está el millón de dólares perdidos. Gertrudis celebra que el éxito en el juicio del narcotraficante le abre las puertas a que todos ellos confíen en su Escritorio Jurídico. Alberto va saliendo de la casa Corona, cuando Guillermo lo intercepta en su moto; amenazante, se levanta la visera del casco y queda al descubierto ante su rival." type="episode" contentRating="NONADULT" duration="3191000" grandparentArt="https://cdn-images.watch4.com/1080/3/1673084.jpg" grandparentGuid="plex://show/68bad9a39aa661c3574d4960" grandparentKey="/library/metadata/68bad9a39aa661c3574d4960" grandparentRatingKey="68bad9a39aa661c3574d4960" grandparentThumb="https://cdn-images.watch4.com/1920/2/1673084.jpg" grandparentTitle="Corazon Traicionado" grandparentType="show" index="37" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1673084.jpg" title="Corazón Traicionado - S01:E37" userState="0"><Image alt="Corazón Traicionado - S01:E37" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E37" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E37" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1773791869" duration="3192000" endsAt="1773795061" id="69b0b83aba3a6d319e0e7122" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1773813607" duration="3191000" endsAt="1773816798" id="69b1611bb6ba59737061bad5" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1773843901" duration="3057000" endsAt="1773846958" id="69b1611bb6ba59737061badf" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1773874784" duration="3191000" endsAt="1773877975" id="69b1611bb6ba59737061bae9" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69b0b839ba3a6d319e0e7108" key="/library/metadata/69b0b839ba3a6d319e0e7108" ratingKey="69b0b839ba3a6d319e0e7108" summary="Para decidir quién comprará las yeguas, Florencia reta a Victoria a una carrera por el llano donde la ganadora se quedará con los animales; Victoria acepta el desafío. Una inesperada visita de Hilario asusta a Federico, mientras que Fernanda no se amilana y le recuerda a su medio hermano que Victoria es quien lo está dejando en la ruina; Hilario le asegura a Fernanda que no permitirá que su propia hija lo despoje de lo que le pertenece. En medio de la carrera, Florencia desenfunda su arma y dispara al viento para obligar a Victoria a detenerse; esta última se extrańa al ver a la seńora Del Casal armada, dispuesta a matar, pero Florencia es incapaz de seguir su plan, por lo que decide terminar la carrera. Frente a un confundido Nicolás, Victoria irrumpe en la hacienda Los Samanes para exigirle a Florencia una explicación sobre el por qué ésta cavó una fosa cerca del lugar donde disparó durante la carrera: debido a que Florencia niega su participación en la excavación, Victoria arremete en contra de ella para que confiese su intención de asesinarla." type="episode" contentRating="NONADULT" duration="2450000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="101" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E101" userState="0"><Image alt="S01:E101" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E101" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E101" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1773798138" duration="3077000" endsAt="1773801215" id="69b0b83aba3a6d319e0e7124" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1773819985" duration="2944000" endsAt="1773822929" id="69b1611bb6ba59737061bad7" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1773850145" duration="2944000" endsAt="1773853089" id="69b1611bb6ba59737061bae1" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69b0b839ba3a6d319e0e7109" key="/library/metadata/69b0b839ba3a6d319e0e7109" ratingKey="69b0b839ba3a6d319e0e7109" summary="Eugenia se siente incómoda cuando Miguel evidencia que gusta de ella y asegura estar dispuesto a conquistarla. Clementina le entrega a Victoria un ramo de flores que acaba de traerle un mensajero y que le envía Builder; la joven Guanipa evidencia preferir el de Nicolás. Nicolás se presenta en casa de Carmencita a avisarle a Victoria lo ocurrido a Hilario; la muchacha advierte que ya estaba enterada y que a su padre no le pasó nada antes de reprocharle el beso que le estuvo dando a Liliana esa mańana y que ella vio en una foto. Nicolás busca a Victoria en la universidad para asegurarle que está dispuesto a hacer cualquier cosa por reconquistarla, pues para él no existe más nadie; Guanipa, orgullosa, lo trata con cierto desprecio y, frente a él, llama a Builder para aceptar la invitación que le hiciera anteriormente." type="episode" contentRating="NONADULT" duration="3091000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="20" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E020" userState="0"><Image alt="S01:E020" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E020" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E020" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1773837745" duration="3090000" endsAt="1773840835" id="69b1611bb6ba59737061badd" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1773868762" duration="2957000" endsAt="1773871719" id="69b1611bb6ba59737061bae7" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69b0b83aba3a6d319e0e710a" key="/library/metadata/69b0b83aba3a6d319e0e710a" ratingKey="69b0b83aba3a6d319e0e710a" summary="Max impaciente, quiere saber de su hermana, Julia. El plan de ellos es intercambiarla por Ezequiel para luego matarlo. En un mensaje de voz Julia le comunica la hora y el día del intercambio y Max lo acompańará." type="episode" contentRating="NONADULT" duration="3033000" grandparentArt="https://cdn-images.watch4.com/10