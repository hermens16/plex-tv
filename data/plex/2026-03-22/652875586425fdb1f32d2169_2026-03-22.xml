8b9238e1cdb8a" slug="sports" tag="Sports" type="directory" context="tag.genre"/><Media beginsAt="1774171800" duration="1800000" endsAt="1774173600" id="69ad6cab182d3d80391ee598" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69ad6ca8182d3d80391ee58e" key="/library/metadata/69ad6ca8182d3d80391ee58e" ratingKey="69ad6ca8182d3d80391ee58e" summary="After heading inland for a whirlwind adventure in the Sahara Desert, the crew says farewell to Lucy as she heads home to Australia. Back in Algiers, Sam, Erwan, and Dihya visit one of the country&apos;s leading digital agencies to discuss their journey and go for one last surf in some perfect longboard waves. Before leaving the country, Sam and Erwan talk with local surfers Dihya and Walid about the future of surfing in Algeria and how the emergence of the sport could impact the people there." type="episode" contentRating="NR" duration="1800000" grandparentArt="https://images.frequency.com/video/7381010443655473386/solid/rectangle/w1920_h1080/1a57p19h14pzx14ptewfmorw31.jpg" grandparentGuid="plex://show/690161068c0415b0db4efc5f" grandparentKey="/library/metadata/690161068c0415b0db4efc5f" grandparentRatingKey="690161068c0415b0db4efc5f" grandparentThumb="https://provider-static.plex.tv/epg/cms/production/8a626fbd-6e1b-48ad-b36a-c634423b9677/2000X3000_WSL_VERT.jpg" grandparentTitle="Brilliant Corners" grandparentType="show" index="3" originallyAvailableAt="2025-10-06T17:00:18Z" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://images.frequency.com/video/7381010430892568360/solid/rectangle/w1920_h1080/18sff3i0h8n1v17tnn2g02nr9j.jpg" title="Trans-Saharan Highway | Brilliant Corners: Algeria, Episode 3" userState="0" year="2025"><Image alt="Trans-Saharan Highway | Brilliant Corners: Algeria, Episode 3" type="coverArt" url="https://images.frequency.com/video/7381010443655473386/solid/rectangle/w1920_h1080/1a57p19h14pzx14ptewfmorw31.jpg"/><Image alt="Trans-Saharan Highway | Brilliant Corners: Algeria, Episode 3" type="coverPoster" url="https://provider-static.plex.tv/epg/cms/production/8a626fbd-6e1b-48ad-b36a-c634423b9677/2000X3000_WSL_VERT.jpg"/><Image alt="Trans-Saharan Highway | Brilliant Corners: Algeria, Episode 3" type="snapshot" url="https://images.frequency.com/video/7381010430892568360/solid/rectangle/w1920_h1080/18sff3i0h8n1v17tnn2g02nr9j.jpg"/><Genre filter="genre=620143f98578b9238e1cdb8a" id="620143f98578b9238e1cdb8a" key="/library/sections/home/all?genre=620143f98578b9238e1cdb8a" ratingKey="genre_620143f98578b9238e1cdb8a" slug="sports" tag="Sports" type="directory" context="tag.genre"/><Media beginsAt="1774157400" duration="1800000" endsAt="1774159200" id="69ad6cab182d3d80391ee592" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69ad6ca8182d3d80391ee58f" key="/library/metadata/69ad6ca8182d3d80391ee58f" ratingKey="69ad6ca8182d3d80391ee58f" summary="Host and Longboard Champion Sam Bleakley travels to Algeria with Australian longboarder and writer Lucy Small, French surfer and adventurer Erwan Simon, and local Dihya Nasri, the only female surfer in all of Algeria. They continue to explore the over 1,000 miles of mostly unsurfed Mediterranean coastline, paddling out at a slabbing wave near the capital city of Algiers. Sam Bleakley, Lucy Small, Erwan Simon, and Dihya Nasri have a dawn patrol session at a nearby break and meet some of the local surfers in the tight-knit community as they continue to explore Algeria, one of the Brilliant Corners of the earth." type="episode" contentRating="NR" duration="1800000" grandparentArt="https://images.frequency.com/video/7381010443655473386/solid/rectangle/w1920_h1080/1a57p19h14pzx14ptewfmorw31.jpg" grandparentGuid="plex://show/690161068c0415b0db4efc5f" grandparentKey="/library/metadata/690161068c0415b0db4efc5f" grandparentRatingKey="690161068c0415b0db4efc5f" grandparentThumb="https://provider-static.plex.tv/epg/cms/production/8a626fb