<MediaContainer offset="0" totalSize="11" identifier="tv.plex.provider.epg" size="11"><Video guid="plex://episode/69d4f9cfd9cd0a3327e58747" key="/library/metadata/69d4f9cfd9cd0a3327e58747" ratingKey="69d4f9cfd9cd0a3327e58747" summary="Victoria decide darle un voto de confianza a Nicolįs y lo deja huir con su caballo; antes de irse,la besa. Moncho pide a Florencia le diga en dónde estįn las reses robadas o la pondrį en evidencia ante Hilario; la joven lo convence de que no lo haga. Nicolįs y Leopoldo advierten a Florencia que ya Hilario puede saber que ella es la espķa que los ayuda; la joven estį dispuesta a enfrentarse a Guanipa." type="episode" contentRating="NONADULT" duration="3040000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="48" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E048" userState="0"><Image alt="S01:E048" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E048" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E048" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1776342936" duration="3040000" endsAt="1776345976" id="69d79cef6ad16397528a861b" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1776373330" duration="2907000" endsAt="1776376237" id="69d79cef6ad16397528a8625" onAir="0"