<MediaContainer offset="0" totalSize="8" identifier="tv.plex.provider.epg" size="8"><Video guid="plex://episode/69d8ed8f938654e74355a034" key="/library/metadata/69d8ed8f938654e74355a034" ratingKey="69d8ed8f938654e74355a034" summary="Fernando ameaça Jeli para que lhe tire o menino, mas Leandro avisa-o de que é seu pai. Fausto espera o filho Gregório, bate-lhe, expulsa-o de casa e decide tirar-lhe todos os pertences e regalias. Ezequiel opta por prender Júlia; Gregório vem buscar a mulher, Celso encontra-os, enfurecido e drogado, e agride-os, ferindo a jovem." type="episode" contentRating="NONADULT" duration="2921000" grandparentArt="https://d3dpwvkv1y8pcn.cloudfront.net/Images/S3/WAPIS/272_1672724.jpg" grandparentGuid="plex://show/687fff08c082969749e5c0d6" grandparentKey="/library/metadata/687fff08c082969749e5c0d6" grandparentRatingKey="687fff08c082969749e5c0d6" grandparentThumb="https://d3dpwvkv1y8pcn.cloudfront.net/Images/S3/WAPIS/wedotv_amor_piel_salvaje20628_1672563-portrait.jpg" grandparentTitle="Piel Salvaje" grandparentType="show" index="99" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://d3dpwvkv1y8pcn.cloudfront.net/Images/S3/WAPIS/272_1672724.jpg" title="S01E099" userState="0"><Image alt="S01E099" type="coverArt" url="https://d3dpwvkv1y8pcn.cloudfront.net/Images/S3/WAPIS/272_1672724.jpg"/><Image alt="S01E099" type="coverPoster" url="https://d3dpwvkv1y8pcn.cloudfront.net/Images/S3/WAPIS/wedotv_amor_piel_salvaje20628_1672563-portrait.jpg"/><Image alt="S01E099" type="snapshot" url="https://d3dpwvkv1y8pcn.cloudfront.net/Images/S3/WAPIS/272_1672724.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1777075407" duration="2921000" endsAt="1777078328" id="69e2281ff4ad7be36fb2a8af" onAir="0" premiere="0" videoResolution="720" origin=