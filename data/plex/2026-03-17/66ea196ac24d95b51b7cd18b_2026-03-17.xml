 beginsAt="1773714241" duration="3107000" endsAt="1773717348" id="69aebebbfdcb297b7e27186f" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1773739009" duration="2979000" endsAt="1773741988" id="69b0b83aba3a6d319e0e7111" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1773769844" duration="3113000" endsAt="1773772957" id="69b0b83aba3a6d319e0e711b" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69ad6c81182d3d80391ee1db" key="/library/metadata/69ad6c81182d3d80391ee1db" ratingKey="69ad6c81182d3d80391ee1db" summary="Ezequiel castiga a Gregorio por su relación con Julia, es un Aragón. Julia está desaparecida y no se conoce su paradero, es parte de la venganza contra Ezequiel. Max insiste en ayudar a Camila y ella reconoce que siente algo por él." type="episode" contentRating="NONADULT" duration="3204000" grandparentArt="https://cdn-images.watch4.com/1080/3/1672724.jpg" grandparentGuid="plex://show/66ea19708651b52ba9cee047" grandparentKey="/library/metadata/66ea19708651b52ba9cee047" grandparentRatingKey="66ea19708651b52ba9cee047" grandparentThumb="https://cdn-images.watch4.com/1920/2/1672724.jpg" grandparentTitle="Piel Salvaje" grandparentType="show" index="17" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1672724.jpg" title="S01:E17" userState="0"><Image alt="S01:E17" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1672724.jpg"/><Image alt="S01:E17" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1672724.jpg"/><Image alt="S01:E17" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1672724.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1773720467" duration="3078000" endsAt="1773723545" id="69aebebbfdcb297b7e271871" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69aebeb5fdcb297b7e271770" key="/library/metadata/69aebeb5fdcb297b7e271770" ratingKey="69aebeb5fdcb297b7e271770" summary="Guillermo tiene la idea fija de llevarse a “su mujer” y a Ignacio con él. Alberto le advierte a Gertrudis que hará lo imposible por liberar a Malena de la violencia de Pablo. Elvis aconseja a Ricardo que se sincere con las Marías o todas acabarán con él - Virginia llega al encuentro de Liz y Augusto, dispuesta a irse con la pareja; para sorpresa de todos, aparece Carmen. Alberto le pide matrimonio a Lorena." type="episode" contentRating="NONADULT" duration="3217000" grandparentArt="https://cdn-images.watch4.com/1080/3/1673084.jpg" grandparentGuid="plex://show/68bad9a39aa661c3574d4960" grandparentKey="/library/metadata/68bad9a39aa661c3574d4960" grandparentRatingKey="68bad9a39aa661c3574d4960" grandparentThumb="https://cdn-images.watch4.com/1920/2/1673084.jpg" grandparentTitle="Corazon Traicionado" grandparentType="show" index="36" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1673084.jpg" title="Corazón Traicionado - S01:E36" userState="0"><Image alt="Corazón Traicionado - S01:E36" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E36" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E36" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1773704902" duration="3218000" endsAt="1773708120" id="69aebebbfdcb297b7e27186c" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1773727207" duration="3217000" endsAt="1773730424" id="69b0b83aba3a6d319e0e710d" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1773757549" duration="3083000" endsAt="1773760632" id="69b0b83aba3a6d319e0e7117" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1773788652" duration="3217000" endsAt="1773791869" id="69b0b83aba3a6d319e0e7121" onAir="1" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69aebeb8fdcb297b7e2717eb" key="/library/metadata/69aebeb8fdcb297b7e2717eb" ratingKey="69aebeb8fdcb297b7e2717eb" summary="Frente a Hilario Guanipa, su hija Victoria y Genara, Felipe Osuna informa a Adelaida de Guanipa que Carlos Hansen sufrió un accidente, pero sigue con vida; el joven Osuna quiere darle a la seńora un mensaje que su jefe le envió antes de lo ocurrido, pero la mujer, aturdida, sale corriendo de su casa sin escucharlo; Hilario ordena a todos que le dejen tranquila. Sintiéndose culpable, Adelaida llora desconsolada creyendo a su amado Hansen en peligro de muerte cuando el hombre se aparece ante ella sano y salvo explicándole que todo fue una trampa que montó para distraer la vigilancia de Hilario y poder sacarla de la hacienda. Fernanda de Alcoy avisa a Florencia que ya tiene casi todo cuadrado para lo que van a hacer en contra de Victoria; Fernanda, quien se enteró de que Victoria botó a su padre de su casa, avisa a Florencia que deben aprovechar esa oportunidad para llevar a cabo su plan contra la joven Guanipa y que toda la culpa recaiga sobre Hilario; la joven seńora Del Casal le pide a su tía política le dé dos días para prepararse para el evento." type="episode" contentRating="NONADULT" duration="2366000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="100" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E100" userState="0"><Image alt="S01:E100" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E100" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E100" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1773711164" duration="3077000" endsAt="1773714241" id="69aebebbfdcb297b7e27186e" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1773733615" duration="2944000" endsAt="1773736559" id="69b0b83aba3a6d319e0e710f" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1773763823" duration="2944000" endsAt="1773766767" id="69b0b83aba3a6d319e0e7119" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69aebeb8fdcb297b7e2717ec" key="/library/metadata/69aebeb8fdcb297b7e2717ec" ratingKey="69aebeb8fdcb297b7e2717ec" summary="Fernanda impide que Nicolás siga espiando la conversación entre Jonás y Builder. Una emocionada Antonieta comenta con Fernanda que existe la posibilidad de salir en la película que va a filmar Jack aunque sea como extra, cosa que la hace muy feliz, pues todas sus amigas de la alta sociedad se van a morir de envidia.Victoria se finge furiosa ante Adelaida al recibir un ramo de flores que le envía Nicolás, aunque, a solas, admite que se muere por perdonarlo." type="episode" contentRating="NONADULT" duration="3073000" grandparentArt="htt