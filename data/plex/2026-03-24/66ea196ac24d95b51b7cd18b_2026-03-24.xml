tory" context="tag.genre"/><Media beginsAt="1774324724" duration="2973000" endsAt="1774327697" id="69b8a143b8f9cce49c70d8a2" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69b6a71a1c66092199aaf323" key="/library/metadata/69b6a71a1c66092199aaf323" ratingKey="69b6a71a1c66092199aaf323" summary="Una decidida Adriana amenaza con gritar si Carlos Raúl no la suelta; éste sella sus labios con un inesperado beso." type="episode" contentRating="NONADULT" duration="2948000" grandparentArt="https://cdn-images.watch4.com/1080/3/1672730.jpg" grandparentGuid="plex://show/69b0b83aba3a6d319e0e710b" grandparentKey="/library/metadata/69b0b83aba3a6d319e0e710b" grandparentRatingKey="69b0b83aba3a6d319e0e710b" grandparentThumb="https://cdn-images.watch4.com/1920/2/1672730.jpg" grandparentTitle="Te Tengo en Salsa" grandparentType="show" index="6" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1672730.jpg" title="S01:E06" userState="0"><Image alt="S01:E06" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1672730.jpg"/><Image alt="S01:E06" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1672730.jpg"/><Image alt="S01:E06" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1672730.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1774318605" duration="3076000" endsAt="1774321681" id="69b8a143b8f9cce49c70d8a0" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69b8a13fb8f9cce49c70d883" key="/library/metadata/69b8a13fb8f9cce49c70d883" ratingKey="69b8a13fb8f9cce49c70d883" summary="La casa Corona comienza a vestirse de gala para la celebración del matrimonio entre Lorena y Alberto. Gertrudis le recuerda a Lorena su pacto de silencio y la amenaza con su vida Alberto sostiene una conversación de “hombre a hombre” con el pequeńo Ignacio. El nińo, inocente, pregunta qué va a pasar con su papá “Guille”." type="episode" contentRating="NONADULT" duration="3223000" grandparentArt="https://cdn-images.watch4.com/1080/3/1673084.jpg" grandparentGuid="plex://show/68bad9a39aa661c3574d4960" grandparentKey="/library/metadata/68bad9a39aa661c3574d4960" grandparentRatingKey="68bad9a39aa661c3574d4960" grandparentThumb="https://cdn-images.watch4.com/1920/2/1673084.jpg" grandparentTitle="Corazon Traicionado" grandparentType="show" index="43" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1673084.jpg" title="Corazón Traicionado - S01:E43" userState="0"><Image alt="Corazón Traicionado - S01:E43" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E43" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E43" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1774309250" duration="3224000" endsAt="1774312474" id="69b8a143b8f9cce49c70d89d" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774332007" duration="3223000" endsAt="1774335230" id="69b949fe65755a1669753f40" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774362013" duration="3089000" endsAt="1774365102" id="69b949fe65755a1669753f4a" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774392683" duration="3223000" endsAt="1774395906" id="69b949fe65755a1669753f54" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69b8a141b8f9cce49c70d884" key="/library/metadata/69b8a141b8f9cce49c70d884" ratingKey="69b8a141b8f9cce49c70d884" summary="Tras haber encontrado a Federico entre los matorrales buscando algo, Victoria le ordena a uno de sus peones escoltar al joven Alcoy hasta la hacienda Los Samanes; Victoria deja en claro que ella es quién manda en sus tierras. Una Vez que Nicolás recibe en la hacienda Los Samanes a sus tíos –Fernanda y Leopoldo- y a su prima Eugenia, Federico entra al lugar escoltado por los peones de Victoria; esta última explica que el joven Alcoy no sólo amenazó a uno de sus hombres sino que además lo encontró hurgando algo en Cantarrana. Caída la noche, Genara le hace ver a Victoria que mientras ella suspira por su amado, Nicolás prepara una fiesta en el mismo terreno donde éste le propuso matrimonio; Victoria jura vengarse de él." type="episode" contentRating="NONADULT" duration="2484000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="107" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E107" userState="0"><Image alt="S01:E107" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E107" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E107" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1774315530" duration="3075000" endsAt="1774318605" id="69b8a143b8f9cce49c70d89f" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774338447" duration="2942000" endsAt="1774341389" id="69b949fe65755a1669753f42" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774368319" duration="2942000" endsAt="1774371261" id="69b949fe65755a1669753f4c" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69b8a141b8f9cce49c70d885" key="/library/metadata/69b8a141b8f9cce49c70d885" ratingKey="69b8a141b8f9cce49c70d885" summary="Victoria y Nicolás se besan enamorados; él le promete que siempre estará a su lado antes de sumergirse con ella en el mar en medio de un apasionado beso. Antonieta y Eugenia exigen a Leopoldo les diga qué está ocurriendo con Fernanda que no ha aparecido desde temprano. Hilario disfruta la velada con Florencia en un parque de diversiones donde la joven lo abraza y asegura saber que él la va a proteger siempre; mientas que, internamente, contiene la rabia que siente por el hombre. Hansen siente cierta decepción cuando Adelaida sugiere que lo quiere como un hermano y confía en que él no sería capaz de ocultarle algo que le hiciera dańo. Carlos está a punto de confesarle su amor a la mujer, pero desiste cuando ella le habla de que su único sueńo es que su amor por Hilario convierta su matrimonio en algo distinto a lo que es actualmente." type="episode" contentRating="NONADULT" duration="3072000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="26" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E026" userState="0"><Image alt="S01:E026" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E026" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E026" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1774355870" duration="3071000" endsAt="1774358941" id="69b949fe65755a1669753f48" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774386674" duration="2937000" endsAt="1774389611" id="69b949fe65755a1669753f52" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69b8a142b8f9cce49c70d886" key="/library/metadata/69b8a142b8f9cce49c70d886" ratingKey="69b8a142b8f9cce49c70d886" summary="Max pide matrimonio a Camila, ella no acepta, reconoce que lo ama, pero al saber la verdad él se decepcionaría y se alejaría. Roberto amenaza con contar a Max lo que sabe y hablará con Camila para negociar su silencio. Rosa Blanco quiere venganza." type="episode" contentRating="NONADULT" duration="2982000" grandparentArt="https://cdn-images.watch4.com/1080/3/1672724.jpg" grandparentGuid="plex://show/66ea19708651b52ba9cee047" grandparentKey="/library/metadata/66ea19708651b52ba9cee047" grandparentRatingKey="66ea19708651b52ba9cee047" grandparentThumb="https://cdn-images.watch4.com/1920/2/1672724.jpg" grandparentTitle="Piel Salvaje" grandparentType="show" index="25" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1672724.jpg" title="S01:E25" userState="0"><Image alt="S01:E25" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1672724.jpg"/><Image alt="S01:E25" type="coverPoster" url="htt