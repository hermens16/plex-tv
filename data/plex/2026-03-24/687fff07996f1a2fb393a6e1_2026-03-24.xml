<MediaContainer offset="0" totalSize="8" identifier="tv.plex.provider.epg" size="8"><Video guid="plex://episode/69b2092c4cb2ba83c65be7dc" key="/library/metadata/69b2092c4cb2ba83c65be7dc" ratingKey="69b2092c4cb2ba83c65be7dc" summary="A família e os amigos estăo presentes na festa. Camila, linda e deslumbrante, causa impacto e Ezequiel apresenta-a como a futura Sra. López Méndez, mas ela é incapaz de responder aos surpreendentes tiros que ferem Ezequiel. Marcelina, culpada, esclarece que os tiros năo eram para Ezequiel, mas para matar Camila." type="episode" contentRating="NONADULT" duration="2687000" grandparentArt="https://d3dpwvkv1y8pcn.cloudfront.net/Images/S3/WAPIS/272_1672724.jpg" grandparentGuid="plex://show/687fff08c082969749e5c0d6" grandparentKey="/library/metadata/687fff08c082969749e5c0d6" grandparentRatingKey="687fff08c082969749e5c0d6" grandparentThumb="https://d3dpwvkv1y8pcn.cloudfront.net/Images/S3/WAPIS/wedotv_amor_piel_salvaje20282_1672496-portrait.jpg" grandparentTitle="Piel Salvaje" grandparentType="show" index="67" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://d3dpwvkv1y8pcn.cloudfront.net/Images/S3/WAPIS/272_1672724.jpg" title="S01E067" userState="0"><Image alt="S01E067" type="coverArt" url="https://d3dpwvkv1y8pcn.cloudfront.net/Images/S3/WAPIS/272_1672724.jpg"/><Image alt="S01E067" type="coverPoster" url="https://d3dpwvkv1y8pcn.cloudfront.net/Images/S3/WAPIS/wedotv_amor_piel_salvaje20282_1672496-portrait.jpg"/><Image alt="S01E067" type="snapshot" url="https://d3dpwvkv1y8pcn.cloudfront.net/Images/S3/WAPIS/272_1672724.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1774309365" duration="3089000" endsAt="1774312454" id="69b9495ec2e967105c781d77" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video