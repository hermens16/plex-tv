e="directory" context="tag.genre"/><Media beginsAt="1774663896" duration="3078000" endsAt="1774666974" id="69bde774d7287daa104f95a1" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69bbed0199da3ffc7c54262b" key="/library/metadata/69bbed0199da3ffc7c54262b" ratingKey="69bbed0199da3ffc7c54262b" summary="Max y Ezequiel se enfrentan por Camila. Astrid trata de manipular a Roberto para sacarle información a cambio de dinero. Max acusa a Camila de prostituta y decide sacarla de su vida. El regreso de Rosa Blanco es traumático." type="episode" contentRating="NONADULT" duration="3081000" grandparentArt="https://cdn-images.watch4.com/1080/3/1672724.jpg" grandparentGuid="plex://show/66ea19708651b52ba9cee047" grandparentKey="/library/metadata/66ea19708651b52ba9cee047" grandparentRatingKey="66ea19708651b52ba9cee047" grandparentThumb="https://cdn-images.watch4.com/1920/2/1672724.jpg" grandparentTitle="Piel Salvaje" grandparentType="show" index="28" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1672724.jpg" title="S01:E28" userState="0"><Image alt="S01:E28" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1672724.jpg"/><Image alt="S01:E28" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1672724.jpg"/><Image alt="S01:E28" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1672724.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1774670032" duration="2955000" endsAt="1774672987" id="69bde774d7287daa104f95a3" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774695312" duration="3081000" endsAt="1774698393" id="69be901cfff63a00989e8f8b" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774725827" duration="2947000" endsAt="1774728774" id="69be901cfff63a00989e8f95" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69bde771d7287daa104f9584" key="/library/metadata/69bde771d7287daa104f9584" ratingKey="69bde771d7287daa104f9584" summary="Pablo recibe la visita de un delincuente que le facilita un arma sin registro, para que pueda matar a su mujer sin ser rastreado. Alberto trabaja en un artículo para el periódico, cuando Lorena llega a su encuentro; siguiendo instrucciones de Gertrudis, le asoma a Alberto que Claudio está enamorado de su mamá." type="episode" contentRating="NONADULT" duration="3163000" grandparentArt="https://cdn-images.watch4.com/1080/3/1673084.jpg" grandparentGuid="plex://show/68bad9a39aa661c3574d4960" grandparentKey="/library/metadata/68bad9a39aa661c3574d4960" grandparentRatingKey="68bad9a39aa661c3574d4960" grandparentThumb="https://cdn-images.watch4.com/1920/2/1673084.jpg" grandparentTitle="Corazon Traicionado" grandparentType="show" index="47" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1673084.jpg" title="Corazón Traicionado - S01:E47" userState="0"><Image alt="Corazón Traicionado - S01:E47" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E47" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E47" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1774654625" duration="3164000" endsAt="1774657789" id="69bde774d7287daa104f959e" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774677607" duration="3163000" endsAt="1774680770" id="69be901cfff63a00989e8f85" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774707470" duration="3029000" endsAt="1774710499" id="69be901cfff63a00989e8f8f" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774737985" duration="3163000" endsAt="1774741148" id="69be901cfff63a00989e8f99" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69bde772d7287daa104f9585" key="/library/metadata/69bde772d7287daa104f9585" ratingKey="69bde772d7287daa104f9585" summary="Apelando a la confianza que existe entre ellas, Florencia indaga con Fernanda sobre la desaparición de Victoria; la seńora Alcoy afirma haber dado instrucciones precisas para preparar un secuestro, pero no se llevó a cabo. Convencida de que Federico está detrás del secuestro de Victoria, Genara se comunica con el joven Alcoy para ofrecerle un trato: la vida de Victoria por el maletín con dinero que acaba de encontrar.Caída la noche, Federico –en busca de ayuda- le revela a su madre ser el responsable del secuestro de Victoria; después de haber recuperado el maletín con dinero, Federico intentó que los hombres que contrató liberaran a Victoria, pero los hombres se rehusaron; Federico teme por la vida de Guanipa. Una vez que Sergio escucha a Victoria hablar sobre su amor atropellado por Nicolás, se convence de que Victoria sueńa con que su amado la rescate. Ante la llegada de Adelaida, Carmencita consuela a su hija, asegurándole que Victoria será liberada. Antes de ser trasladados a otro lugar; Sergio Escalante le propone matrimonio a Victoria." type="episode" contentRating="NONADULT" duration="2461000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="111" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E111" userState="0"><Image alt="S01:E111" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E111" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E111" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1774660864" duration="3032000" endsAt="1774663896" id="69bde774d7287daa104f95a0" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774683984" duration="2899000" endsAt="1774686883" id="69be901cfff63a00989e8f87" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774713713" duration="2899000" endsAt="1774716612" id="69be901cfff63a00989e8f91" onAir="1" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69bde772d7287daa104f9586" key="/library/metadata/69bde772d7287daa104f9586" ratingKey="69bde772d7287daa104f9586" summary="Hansen advierte a Hilario que está decidido a contarle a Adelaida la verdad porque no se siente bien mintiéndole; Guanipa acepta que el hombre lo haga, pero le ruega que no mencione a la otra mujer con la que él está involucrado. Nicolás se atreve a pedirle a Victoria que se casen; la muchacha acepta convencida de que lo ama con locura. Florencia informa a Fernanda que todo salió como planearon e Hilario cayó en la trampa. Nicolás decide regresar a Los Samanes en busca de los papeles que encontró ahí por temor a que Hilario o uno de sus hombres los consiga." type="episode" contentRating="NONADULT" duratio