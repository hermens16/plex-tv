<MediaContainer offset="0" totalSize="13" identifier="tv.plex.provider.epg" size="13"><Video guid="plex://episode/69cfb3e8c6e0d15f9383a217" key="/library/metadata/69cfb3e8c6e0d15f9383a217" ratingKey="69cfb3e8c6e0d15f9383a217" summary="Tras descubrir a Florencia en compańía de Hilario, Nicolás acusa a Guanipa de estar manipulando a la mujer para que ésta le de información sobre la investigación que realiza Nicolás sobre la muerte de su padre. Mientras Hilario admite ante su hija Victoria ser el culpable del incendio que azota las tierras de Cantarrana por su afán de vengarse de Nicolás; un peón le notifica a Nicolás que un feroz incendio arrasa con los maizales de Los Samanes. Sergio acepta la propuesta de matrimonio de Victoria y espera que algún día lo ame tanto como él." type="episode" duration="2945000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="125" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E125 - Episodio 125" userState="0"><Image alt="S01:E125 - Episodio 125" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E125 - Episodio 125" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E125 - Episodio 125" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1775954356" duration="3078000" endsAt="1775957434" id="69d1ade89c21c35