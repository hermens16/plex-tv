nt="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1672724.jpg" title="S01:E44" userState="0"><Image alt="S01:E44" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1672724.jpg"/><Image alt="S01:E44" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1672724.jpg"/><Image alt="S01:E44" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1672724.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1775969957" duration="3650000" endsAt="1775973607" id="69d1ade89c21c35657b0dd57" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1775991487" duration="3143000" endsAt="1775994630" id="69d256ae8c1f6132b1aadd7a" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1776022239" duration="3009000" endsAt="1776025248" id="69d256ae8c1f6132b1aadd84" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69d1ade89c21c35657b0dd3b" key="/library/metadata/69d1ade89c21c35657b0dd3b" ratingKey="69d1ade89c21c35657b0dd3b" summary="Por más que Hilario insiste en rehacer su vida junto a Florencia, ésta cree que aún existen cosas por perder antes de ser feliz al lado de Hilario Guanipa Ante Federico, Fernanda debe admitir que asesinó a Genara; a solas, Federico guarda la confesión de su madre que ha grabado en una cámara de video. Después de una semana, Victoria insiste en casarse con Sergio a pesar de que Adelaida y Clementina se niegan; si bien Victoria no ama a Sergio, necesita el apoyo de su madre para ser feliz; Adelaida no quiere que su hija cometa un error. Una vez en la jefatura civil, Carmencita trata de convencer a Victoria de cancelar su matrimonio, mientras que Hilario cree que Sergio obliga a Victoria a casarse; en ese momento, Nicolás se presenta en el lugar para manifestarle a Victoria que Sergio tiene negocios sórdidos con Fernanda, pero Victoria no le cree a Del Casal.Ante Fernanda, Sergio afirma tener su confesión sobre la muerte de Genara, por lo que Fernanda apunta al hombre con su arma; la pareja discute el arma se dispara; Florencia observa como Sergio –herido a muerte- sale del despacho." type="episode" contentRating="NONADULT" duration="2462000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="126" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E126" userState="0"><Image alt="S01:E126" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E126" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E126" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1775957434" duration="3068000" endsAt="1775960502" id="69d1ade89c21c35657b0dd53" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1775980087" duration="2935000" endsAt="1775983022" id="69d256ae8c1f6132b1aadd76" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1776010089" duration="2935000" endsAt="1776013024" id="69d256ae8c1f6132b1aadd80" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69d256aa8c1f6132b1aadd68" key="/library/metadata/69d256aa8c1f6132b1aadd68" ratingKey="69d256aa8c1f6132b1aadd68" summary="Lorena en shock ante el cuerpo sin vida de su comadre y amiga. Pedro, frío, la obliga a verlo a los ojos y le advierte que con un sicario no se juega; que la próxima vez que se le ocurra traicionarlo, la víctima será su hijo. El Juez Montilla afirma que dependiendo de lo que se discuta y los acuerdos a los que lleguen en esa audiencia, podrá revocar o no la libertad bajo fianza de Isabel." type="episode" contentRating="NONADULT" duration="3237000" grandparentArt="https://cdn-images.watch4.com/1080/3/1673084.jpg" grandparentGuid="plex://show/68bad9a39aa661c3574d4960" grandparentKey="/library/metadata/68bad9a39aa661c3574d4960" grandparentRatingKey="68bad9a39aa661c3574d4960" grandparentThumb="https://cdn-images.watch4.com/1920/2/1673084.jpg" grandparentTitle="Corazon Traicionado" grandparentType="show" index="63" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1673084.jpg" title="Corazón Traicionado - S01:E63" userState="0"><Image alt="Corazón Traicionado - S01:E63" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E63" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E63" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1775976850" duration="3237000" endsAt="1775980087" id="69d256ae8c1f6132b1aadd75" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1776006852" duration="3237000" endsAt="1776010089" id="69d256ae8c1f6132b1aadd7f" onAir="1" premiere="0" videoResolution="720" origin="livetv"