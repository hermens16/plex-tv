="https://cdn-images.watch4.com/1080/3/1673084.jpg" grandparentGuid="plex://show/68bad9a39aa661c3574d4960" grandparentKey="/library/metadata/68bad9a39aa661c3574d4960" grandparentRatingKey="68bad9a39aa661c3574d4960" grandparentThumb="https://cdn-images.watch4.com/1920/2/1673084.jpg" grandparentTitle="Corazon Traicionado" grandparentType="show" index="45" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1673084.jpg" title="Corazón Traicionado - S01:E45" userState="0"><Image alt="Corazón Traicionado - S01:E45" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E45" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E45" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1774481803" duration="3080000" endsAt="1774484883" id="69ba9b6e6fcadaf8caf656a7" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774504807" duration="3079000" endsAt="1774507886" id="69bbed0199da3ffc7c542633" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774534551" duration="2945000" endsAt="1774537496" id="69bbed0199da3ffc7c54263d" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774564948" duration="3079000" endsAt="1774568027" id="69bbed0199da3ffc7c542647" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69ba9b6c6fcadaf8caf65687" key="/library/metadata/69ba9b6c6fcadaf8caf65687" ratingKey="69ba9b6c6fcadaf8caf65687" summary="Para evitar más enfrentamientos entre los Guanipa y los Del Casal, Sergio amenaza a Victoria con quitarle el control de Cantarrana, pero una imponente mujer se niega a perder sus tierras. Desde su nuevo hogar en Estados Unidos, Adelaida preocupada se comunica con su madre para saber si su hija finalmente perdonó a Hilario. Sin el consentimiento de Victoria, Sergio llega a la hacienda Los Samanes para entregarle a Nicolás una cantidad de dinero como forma de pago por la inundación de los maizales que ocasionó Victoria, quien llega en ese momento; Nicolás asegura que podría quitarle Cantarrana a Victoria ya que los campesinos de la zona quedaron damnificados, pero Sergio golpea con fuerza a Nicolás para impedírselo." type="episode" contentRating="NONADULT" duration="2477000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="109" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E109" userState="0"><Image alt="S01:E109" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E109" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E109" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1774487934" duration="3041000" endsAt="1774490975" id="69ba9b6e6fcadaf8caf656a9" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774511041" duration="2908000" endsAt="1774513949" id="69bbed0199da3ffc7c542635" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774540651" duration="2908000" endsAt="1774543559" id="69bbed0199da3ffc7c54263f" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69ba9b6c6fcadaf8caf65688" key="/library/metadata/69ba9b6c6fcadaf8caf65688" ratingKey="69ba9b6c6fcadaf8caf65688" summary="Adelaida se molesta con Hilario porque el hombre se niega a darle explicaciones sobre su problema con Nicolás; la seńora se marcha furiosa; mientras que, los hombres se quedan discutiendo porque Del Casal advierte a Guanipa que no piensa permitir que intervenga en su relación con Victoria. Felipe, con el periódico donde apareció la noticia del matrimonio en la mano, se presenta en casa de los Alcoy a pedirle a Antonieta que detenga la farsa de su boda. Victoria nada desnuda en el río de Cantarrana cuando descubre a Nicolás observándola embelesado; el joven, que explica cómo llegó tan rápido hasta ahí, se sorprende cuando su amada comienza a lanzarle piedras a la vez que le exige que se retire cuanto antes del lugar." type="episode" contentRating="NONADULT" duration="3070000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="28" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E028" userState="0"><Image alt="S01:E028" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E028" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E028" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610e