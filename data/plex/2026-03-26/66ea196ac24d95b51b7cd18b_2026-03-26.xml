<MediaContainer offset="0" totalSize="13" identifier="tv.plex.provider.epg" size="13"><Video guid="plex://episode/69b949fc65755a1669753f35" key="/library/metadata/69b949fc65755a1669753f35" ratingKey="69b949fc65755a1669753f35" summary="Mientras Florencia y Fernanda acusan a Victoria del estallido de la represa que Nicolás construía, la joven Guanipa asegura que Federico es un criminal al haber amenazado a los empleados de Cantarrana por su insistencia en buscar un maletín con dinero. Por la presencia de Antonieta y Felipe en la fiesta a la que Carmencita invitó a Clementina, esta última se siente engańada, pues precisamente quería evitar un encuentro con su amado. Cerca de allí, Carmencita interrumpe a Sergio para pedirle que viaje de inmediato a Cantarrana, pues Victoria podría estar cometiendo un error en su afán de controlar la hacienda. Cuando Nicolás le informa a su esposa que el estallido del dique ha inundado los maizales, una furiosa Florencia decide vengarse de Victoria Guanipa.Justo cuando Victoria decide ir a buscar a su padre, una llamada de sus peones le informa que los potreros de Cantarrana están siendo incendiados por Florencia Zapata." type="episode" contentRating="NONADULT" duration="2918000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="108" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E108" userState="0"><Image alt="S01:E108" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E108" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E108" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1774484883" duration="3051000" endsAt="1774487934" id="69ba9b6e6fcadaf8caf656a8" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69b949fd65755a1669753f37" key="/library/metadata/69b949fd65755a1669753f37" ratingKey="69b949fd65755a1669753f37" summary="Max piensa que Camila lo rechazó por Roberto. En confesión con el Padre Tiziano, le aconseja que le cuente toda la verdad a Max, pero ella teme que Roberto la denuncie por asesina. Julia y Gregorio vuelven a encontrarse." type="episode" contentRating="NONADULT" duration="3102000" grandparentArt="https://cdn-images.watch4.com/1080/3/1672724.jpg" grandparentGuid="plex://show/66ea19708651b52ba9cee047" grandparentKey="/library/metadata/66ea19708651b52ba9cee047" grandparentRatingKey="66ea19708651b52ba9cee047" grandparentThumb="https://cdn-images.watch4.com/1920/2/1672724.jpg" grandparentTitle="Piel Salvaje" grandparentType="show" index="26" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1672724.jpg" title="S01:E26" userState="0"><Image alt="S01:E26" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1672724.jpg"/><Image alt="S01:E26" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1672724.jpg"/><Image alt="S01:E26" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1672724.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1774497103" duration="2975000" endsAt="1774500078" id="69ba9b6e6fcadaf8caf656ac" onAir="0" 