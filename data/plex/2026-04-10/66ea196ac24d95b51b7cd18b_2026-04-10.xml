nte." type="episode" contentRating="NONADULT" duration="2992000" grandparentArt="https://cdn-images.watch4.com/1080/3/1672724.jpg" grandparentGuid="plex://show/66ea19708651b52ba9cee047" grandparentKey="/library/metadata/66ea19708651b52ba9cee047" grandparentRatingKey="66ea19708651b52ba9cee047" grandparentThumb="https://cdn-images.watch4.com/1920/2/1672724.jpg" grandparentTitle="Piel Salvaje" grandparentType="show" index="41" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1672724.jpg" title="S01:E41" userState="0"><Image alt="S01:E41" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1672724.jpg"/><Image alt="S01:E41" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1672724.jpg"/><Image alt="S01:E41" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1672724.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1775793928" duration="2993000" endsAt="1775796921" id="69cf0b172ff4bb4e69040750" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69cd10923d7cb988a23b390a" key="/library/metadata/69cd10923d7cb988a23b390a" ratingKey="69cd10923d7cb988a23b390a" summary="Un incrédulo Nicolás trata de entender cómo Victoria pudo arremeter violentamente en contra de Florencia a sabiendas de su embarazo, pues ahora Florencia llora la pérdida de su hijo. En un nuevo día, Nicolás se enfrenta a Victoria, a quien le reprocha haber causado la muerte de su hijo al golpear a Florencia; por más que Victoria trata de convencerlo de que todo es un invento de su esposa; Nicolás está seguro de la culpabilidad de Guanipa. Segura de que todas las pruebas pueden inculpar a Sergio de la muerte de Genara, Fernanda insiste en amenazarlo con acusarlo a la policía si éste no la ayuda a arrebatarle la hacienda Cantarrana a la familia Guanipa, así deba traicionar a Victoria; Sergio no tiene otra salida que aceptar el ofrecimiento de Fernanda. Una vez que Florencia se refugia en Fernanda temerosa de que Nicolás descubra que ella es quien miente sobre la pérdida de su hijo; Eugenia ha escuchado a su madre, a quien le asegura irse junto a su padre apenas éste consiga un lugar donde vivir." type="episode" contentRating="NONADULT" duration="2927000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="123" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E123" userState="0"><Image alt="S01:E123" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E123" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E123" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1775781507" duration="3060000" endsAt="1775784567" id="69cf0b172ff4bb4e6904074c" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69cf0b132ff4bb4e69040731" key="/library/metadata/69cf0b132ff4bb4e69040731" ratingKey="69cf0b132ff4bb4e69040731" summary="Ricardo por primera vez se impone ante Paulina, defendiendo con firmeza lo que siente por María Bonita - Culminado el interrogatorio de Isabel, Janet le espeta que no cree en su inocencia ni en la de Malena – Magda, por cuenta propia, decide y habla con Omar del video-confesión que grabó Lorena." type="episode" contentRating="NONADULT" duration="3225000" grandparentArt="https://cdn-images.watch4.com/1080/3/1673084.jpg" grandparentGuid="plex://show/68bad9a39aa661c3574d4960" grandparentKey="/library/metadata/68bad9a39aa661c3574d4960" grandparentRatingKey="68bad9a39aa661c3574d4960" grandparentThumb="https://cdn-images.watch4.com/1920/2/1673084.jpg" grandparentTitle="Corazon Traicionado" grandparentType="show" index="60" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1673084.jpg" title="Corazón Traicionado - S01:E60" userState="0"><Image alt="Corazón Traicionado - S01:E60" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E60" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E60" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1775778281" duration="3226000" endsAt="1775781507" id="69cf0b172ff4bb4e6904074b" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1775800807" duration="3225000" endsAt="1775804032" id="69cfb3eec6e0d15f9383a512" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1775830739" duration="3091000" endsAt="1775833830" id="69cfb3eec6e0d15f9383a51c" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1775861441" duration="3225000" endsAt="1775864666" id="69cfb3eec6e0d15f9383a526" onAir="1" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69cf0b15