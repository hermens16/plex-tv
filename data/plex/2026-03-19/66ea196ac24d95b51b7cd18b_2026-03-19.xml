3574d4960" grandparentKey="/library/metadata/68bad9a39aa661c3574d4960" grandparentRatingKey="68bad9a39aa661c3574d4960" grandparentThumb="https://cdn-images.watch4.com/1920/2/1673084.jpg" grandparentTitle="Corazon Traicionado" grandparentType="show" index="39" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1673084.jpg" title="Corazón Traicionado - S01:E39" userState="0"><Image alt="Corazón Traicionado - S01:E39" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E39" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E39" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1773903194" duration="3179000" endsAt="1773906373" id="69b2b299452083d8633b4496" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1773932906" duration="3179000" endsAt="1773936085" id="69b2b299452083d8633b44a0" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1773963585" duration="3180000" endsAt="1773966765" id="69b2b299452083d8633b44aa" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69b2b297452083d8633b406c" key="/library/metadata/69b2b297452083d8633b406c" ratingKey="69b2b297452083d8633b406c" summary="Convencido de que Fernanda está detrás de la muerte del caballo del difunto Rosendo, Hilario le advierte a Florencia que su media hermana planea involucrarla en sus trampas; Hilario está seguro de que alguien más recibe dinero de Fernanda para inculpar a Victoria en la muerte de General. Federico intenta imponerse en Los Samanes y pasar por encima de las órdenes de Nicolás, él le deja claro que es un peón más dentro de la hacienda. Florencia se desahoga con Fernanda, pues sabe que Nicolás no la abandonaría por Victoria sino porque realmente no la ama; sin embargo, Nicolás se comunica con su tía para hacerle saber que buscará a Florencia. Moncho le notifica Hilario su renuncia como capataz de Cantarrana. Sergio recibe la visita de Victoria quien ha cambiado de opinión, pues si bien no quiere lastimar a Sergio sí está decidida a olvidar definitivamente a Nicolás del Casal." type="episode" contentRating="NONADULT" duration="2531000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="103" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E103" userState="0"><Image alt="S01:E103" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E103" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E103" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1773909291" duration="2531000" endsAt="1773911822" id="69b2b299452083d8633b4498" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1773939003" duration="3096000" endsAt="1773942099" id="69b2b299452083d8633b44a2" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69b2b297452083d8633b406d" key="/library/metadata/69b2b297452083d8633b406d" ratingKey="69b2b297452083d8633b406d" summary="Hilario quiere que Victoria se olvide para siempre de Nicolás convencido de que el joven la está utilizando para vengarse de él. Leopoldo indaga con Nicolás quién es Florencia; el joven le revela que la muchacha es la hija del difunto capataz de Hilario. Nicolás se presenta en casa de Carmencita a pedirle a Victoria que no se deje convencer por Hilario; la muchacha admite que quiere estar con él, pero sabe que su relación no es posible, por lo que le pide que le dé un tiempo para pensar. Adelaida no cabe en si de la sorpresa cuando Hilario la busca para aclarar las cosas y, aunque al principio se muestra soberbio y la trata como a un objeto, termina arrodillado y admitiendo que no puede vivir sin ella." type="episode" contentRating="NONADULT" duration="3039000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="22" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E022" userState="0"><Image alt="S01:E022" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E022" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E022" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1773926814" duration="3039000" endsAt="1773929853" id="69b2b299452083