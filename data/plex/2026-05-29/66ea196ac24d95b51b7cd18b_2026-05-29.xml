080/3/1672730.jpg" grandparentGuid="plex://show/69b0b83aba3a6d319e0e710b" grandparentKey="/library/metadata/69b0b83aba3a6d319e0e710b" grandparentRatingKey="69b0b83aba3a6d319e0e710b" grandparentThumb="https://cdn-images.watch4.com/1920/2/1672730.jpg" grandparentTitle="Te Tengo en Salsa" grandparentType="show" index="74" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1672730.jpg" title="S01:E74" userState="0"><Image alt="S01:E74" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1672730.jpg"/><Image alt="S01:E74" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1672730.jpg"/><Image alt="S01:E74" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1672730.jpg"/><Genre filter="genre=6a0c2728768cf9b31f6fe02a" id="6a0c2728768cf9b31f6fe02a" key="/library/sections/home/all?genre=6a0c2728768cf9b31f6fe02a" ratingKey="genre_6a0c2728768cf9b31f6fe02a" slug="bingeworthy" tag="Bingeworthy" type="directory" context="tag.genre"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1780048650" duration="3116000" endsAt="1780051766" id="6a10f57fa95e566ad16a1722" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1780078272" duration="3115000" endsAt="1780081387" id="6a10f57fa95e566ad16a172c" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/6a10f57fa95e566ad16a171b" key="/library/metadata/6a10f57fa95e566ad16a171b" ratingKey="6a10f57fa95e566ad16a171b" summary="Hilario acusa sorpresa cuando Victoria le revela que, ya que él estį empeńado en caerse, serį ella misma quien lo termine de tumbar quitįndole Cantarrana; el seńor Guanipa se conmueve cuando su hija, con lįgrimas, le reprocha  que se comporte como si se quisiera morir e intenta tranquilizarla asegurįndole que no va a perder la hacienda como todos creen; sin embargo, sus argumentos no son vįlidos para Victoria, quien le advierte que le llegó el momento de que acepte que ahora ella es mįs fuerte que él. La sorpresa se apodera de Adelaida cuando uno de los acreedores de Hilario la visita para proponerle que él se puede encargar de matar a Guanipa siempre y cuando ella se comprometa a que, una vez que quede viuda, pagarį todas las deudas del hombre; la seńora ordena a Moncho saque al hombre de su casa pues, aunque odia a Hilario, no va a prestarse para que lo maten. Ya en la recepción del matrimonio, Fernanda se tensa cuando Caravaggio, algo pasado de tragos, comenta ante Leopoldo que esa boda, al igual que la de Nicolįs con Florencia, es un error; el seńor Alcoy quiere una explicación de sus palabras, pero el periodista sugiere le pregunte directamente a Nicolįs a qué se referķa cuando le dijo a Victoria que Clementina tuvo mįs valentķa que ellos dos." type="episode" contentRating="NONADULT" duration="3039000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="93" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E093" userState="0"><Image alt="S01:E093" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E093" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E093" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6a0c2728768cf9b31f6fe02a" id="6a0c2728768cf9b31f6fe02a" key="/library/sections/home/all?genre=6a0c2728768cf9b31f6fe02a" ratingKey="genre_6a