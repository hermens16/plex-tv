.jpg"/><Image alt="S01:E40" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1672730.jpg"/><Image alt="S01:E40" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1672730.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1777171073" duration="3091000" endsAt="1777174164" id="69e37a667af351467fb39689" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1777194205" duration="2950000" endsAt="1777197155" id="69e4cbf86c91922768426458" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1777223623" duration="3084000" endsAt="1777226707" id="69e4cbf86c91922768426462" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69e37a647af351467fb39667" key="/library/metadata/69e37a647af351467fb39667" ratingKey="69e37a647af351467fb39667" summary="Max está demasiado dolido y no cree ya en ese amor, advirtiéndole que a partir de ahora se dedicará a odiarla, a olvidarla y que será ella la victima de su propia decisión. Ciego de ira y de dolor, grita a los presentes que se retiren pues no habrá boda." type="episode" contentRating="NONADULT" duration="2821000" grandparentArt="https://cdn-images.watch4.com/1080/3/1672724.jpg" grandparentGuid="plex://show/66ea19708651b52ba9cee047" grandparentKey="/library/metadata/66ea19708651b52ba9cee047" grandparentRatingKey="66ea19708651b52ba9cee047" grandparentThumb="https://cdn-images.watch4.com/1920/2/1672724.jpg" grandparentTitle="Piel Salvaje" grandparentType="show" index="59" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1672724.jpg" title="S01:E59" userState="0"><Image alt="S01:E59" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1672724.jpg"/><Image alt=