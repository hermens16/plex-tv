jpg" title="S01:E43" userState="0"><Image alt="S01:E43" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1672730.jpg"/><Image alt="S01:E43" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1672730.jpg"/><Image alt="S01:E43" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1672730.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1777370093" duration="2964000" endsAt="1777373057" id="69e76f151630e5325edd9372" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1777399934" duration="3098000" endsAt="1777403032" id="69e76f151630e5325edd937c" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69e76f151630e5325edd9365" key="/library/metadata/69e76f151630e5325edd9365" ratingKey="69e76f151630e5325edd9365" summary="Florencia se pregunta si Hilario se referiría también a ella cuando dijo que no podían entrar a Cantarrana; Nicolás indaga qué la hizo cambiar de opinión porque, hasta donde él tenía entendido, su intención era justamente esa. Clementina está feliz porque Carmencita aceptó hospedarla en su casa ahora que sus padres decidieron irse a vivir a la playa. Victoria quiere que Hansen la acompańe a Cantarrana para que se olvide de la tristeza que lo embarga por ese misterioso amor que nadie conoce; el seńor, aunque se niega a viajar, le presta su avioneta para que ella lo haga. Antonieta propone a Jonás adelantar el matrimonio. Leopoldo ratifica su decisión de no aparecer ante su familia porque cree que el hecho de que Fernanda esté en esas tierras significa que su supuesta muerte está ayudando a que se acabe el odio que le impedía regresar a ese lugar." type="episode" contentRating="NONADULT" duration="3074000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="62" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E062 - Episodio 62" userState="0"><Image alt="S01:E062 - Episodio 62" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E062 - Episodio 62" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E062 - Episodio 62" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1777382297" duration="3074000" endsAt="1777385371" id="69e76f151630e5325edd9376" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1777412273" duration="3073000" endsAt="1777415346" id="69e76f151630e5325edd9380" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video></MediaContainer>
