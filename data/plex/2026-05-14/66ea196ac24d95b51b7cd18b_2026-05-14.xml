title="S01:E59" userState="0"><Image alt="S01:E59" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1672730.jpg"/><Image alt="S01:E59" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1672730.jpg"/><Image alt="S01:E59" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1672730.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1778752224" duration="2968000" endsAt="1778755192" id="69fc8631d42030d1f6910d8f" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1778781867" duration="3102000" endsAt="1778784969" id="69fc8631d42030d1f6910d99" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69fc8631d42030d1f6910d82" key="/library/metadata/69fc8631d42030d1f6910d82" ratingKey="69fc8631d42030d1f6910d82" summary="Nicolįs y Florencia se besan con pasión cuando llegan Victoria y Carmencita a la mansión y los sorprenden en plena caricia. El hermoso momento que comparten Felipe y Clementina en el apartamento de playa de él se ve opacado cuando Antonieta insiste en llamar por teléfono al joven y, como él no le contesta, opta por llamar al teléfono celular de Clementina, quien se enfurece ante el descaro de la otra joven.  Victoria interrumpe el beso entre Nicolįs y Florencia con aplausos antes de acusar al joven Del Casal de ser un hipócrita, pues hace apenas unas horas estaba tratando de besarla a ella; Florencia se niega a creerle. Hilario, con la astucia de la experiencia, sabe que Florencia se encuentra vulnerable ante él, por lo que le ofrece que lo escoja en vez de a Nicolįs; Guanipa se le va acercando a la muchacha hasta lograr que la joven acepte el beso que le da. Leopoldo celebra que Fernanda haya decidido regresar Cantarrana; la seńora sabe que él no cree que ella sea capaz de cambiar para bien y que tarde o temprano se irį porque ya nada los puede salvar como pareja." type="episode" contentRating="NONADULT" duration="3057000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="78" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E078" userState="0"><Image alt="S01:E078" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E078" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E078" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1778764535" duration="3057000" endsAt="1778767592" id="69fc8631d42030d1f6910d93" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1778794313" duration="3056000" endsAt="1778797369" id="69fc8631d42030d1f6910d9d" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video></MediaContainer>
