ration="3001000" endsAt="1779625488" id="6a09b5cfad807884834e9c7c" onAir="1" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1779652011" duration="3269000" endsAt="1779655280" id="6a09b5cfad807884834e9c86" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/6a0863ab6123210296d607a4" key="/library/metadata/6a0863ab6123210296d607a4" ratingKey="6a0863ab6123210296d607a4" summary="Victoria le confía a Clementina que Sergio Escalante no le dio el empleo y que, ahora que no quiere tocar ni un céntimo que venga de Hilario Guanipa, va a saber lo que en realidad es empezar de cero. Genara no está muy convencida de la lealtad de Moncho hacia Hilario. La cena organizada por Fernanda para celebrar el regreso con vida de Leopoldo y el matrimonio de Florencia y Nicolás está por dar inicio cuando llega Yosmir con su acostumbrada espontaneidad que causa gran tensión en Eugenia, pues no sabe cuál será la reacción de su madre. Victoria busca a Nicolás para convencerse, una vez más, de que él ya escogió su vida al lado de Florencia y ella debe resignarse, sin embargo, al ver la tristeza en el rostro de su amado, la joven se lamenta de que todo entre ellos terminara tan mal si su amor era tan verdadero." type="episode" contentRating="NONADULT" duration="3039000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="87" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E087" userState="0"><Image alt="S01:E087" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E087" type="coverPoster" url="https://cdn-images.watch4.com