watch4.com/1920/2/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E51" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1774939940" duration="3226000" endsAt="1774943166" id="69c284962e97fd3a776bba88" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774969687" duration="3226000" endsAt="1774972913" id="69c284962e97fd3a776bba92" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1775000366" duration="3227000" endsAt="1775003593" id="69c284962e97fd3a776bba9c" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69c284942e97fd3a776bba6a" key="/library/metadata/69c284942e97fd3a776bba6a" ratingKey="69c284942e97fd3a776bba6a" summary="Convencida de que Nicolás quiere el divorcio para intentar recuperar el amor de Victoria, Florencia se niega a la separación; Nicolás le deja claro a su mujer que no puede estar atado a ella porque no la ama. Caída la noche, Sergio le muestra a su futura esposa el apartamento que ocuparan una vez que contraigan matrimonio; Sergio la besa con pasión. Temprano en la mańana, Clementina encuentra a un desvelado Nicolás en la puerta de su casa esperando a Victoria; Clementina trata de convencer a Del Casal que Victoria pasó la noche con Sergio, pero Nicolás se niega a perder a su amada.Por más que Clementina intenta comprender el por qué Victoria se casará con un hombre que no ama y al que no podrá complacer; Victoria necesita el apoyo de su amiga como testigo en su matrimonio, que se celebrará al siguiente día." type="episode" contentRating="NONADULT" duration="2500000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="115" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E115" userState="0"><Image alt="S01:E115" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E115" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E115" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1774946104" duration="2500000" endsAt="1774948604" id="69c284962e97fd3a776bba8a" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774975851" duration="3030000" endsAt="1774978881" id="69c284962e97fd3a776bba94" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69c284942e97fd3a776bba6f" key="/library/metadata/69c284942e97fd3a776bba6f" ratingKey="69c284942e97fd3a776bba6f" summary="Nicolás afirma que desea vengarse de Hilario lo antes posible, pues ahora también tiene que cobrarle que lo apartara de la mujer que ama. Hilario quiere desaparecer a Nicolás, pero Victoria no quiere tragedias, sino arruinar al joven Del Casal y toda su familia. Adelaida relee las supuestas cartas de Hilario, pero las esconde cuando el hombre llega a su lado; la seńora acepta las caricias de su esposo aunque se siente muy confundida por lo que acaba de descubrir. A Felipe le extrańa cuando Hansen le ordena que prepare una carpeta con todos los negocios que tienen en Cantarrana, pues debe viajar de inmediato para la hacienda. La sorpresa se apodera de Clementina cuando Antonieta la busca para decirle que no se pude casar con Felipe." type="episode" contentRating="NONADULT" duration="3055000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="33" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E033" userState="0"><Image alt="S01:E033" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E033" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E033" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1774963633" duration="3055000" endsAt="1774966688" id="69c284962e97fd3a776bba90" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774994179" duration="3054000" endsAt="1774997233" id="69c284962e97fd3a776bba9a" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69c284952e97fd3a776bba76" key="/library/metadata/69c284952e97fd3a776bba76" ratingKey="69c284952e97fd3a776bba76" summary="Joel toma su desayuno justo en el momento que Beatrice lo sorprende en la fonda Palacios" type="episode" contentRating="NONADULT" duration="2967000" grandparentArt="https://cdn-images.watch4.com/1080/3/1672730.jpg" grandparentGuid="plex://show/69b0b83aba3a6d319e0e7