"69ac1b062d5af6ce92de66f4" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69ac1b022d5af6ce92de66ce" key="/library/metadata/69ac1b022d5af6ce92de66ce" ratingKey="69ac1b022d5af6ce92de66ce" summary="Guillermo le da alcance a Cheo y lo mata; queda apuntando a Alberto y Lorena – En la casa se escuchan los disparos. Gertrudis recuerda que Alberto estaba con ella y se siente morir de que le haya pasado algo a su hijo María Bonita piensa que Ricardo es homosexual. Malena provoca la ira de Pablo." type="episode" contentRating="NONADULT" duration="3199000" grandparentArt="https://cdn-images.watch4.com/1080/3/1673084.jpg" grandparentGuid="plex://show/68bad9a39aa661c3574d4960" grandparentKey="/library/metadata/68bad9a39aa661c3574d4960" grandparentRatingKey="68bad9a39aa661c3574d4960" grandparentThumb="https://cdn-images.watch4.com/1920/2/1673084.jpg" grandparentTitle="Corazon Traicionado" grandparentType="show" index="34" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1673084.jpg" title="Corazón Traicionado - S01:E34" userState="0"><Image alt="Corazón Traicionado - S01:E34" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E34" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E34" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1773532334" duration="3200000" endsAt="1773535534" id="69ac1b062d5af6ce92de66ef" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1773554407" duration="3199000" endsAt="1773557606" id="69ad6c81182d3d80391ee1e3" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1773584497" duration="3065000" endsAt="1773587562" id="69ad6c81182d3d80391ee1ed" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1773615322" duration="3199000" endsAt="1773618521" id="69ad6c81182d3d80391ee1f7" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69ac1b042d5af6ce92de66cf" key="/library/metadata/69ac1b042d5af6ce92de66cf" ratingKey="69ac1b042d5af6ce92de66cf" summary="Luego de recordar el momento en que Rosendo Zapata intentó sobrepasarse con ella, Victoria Guanipa revela a Nicolás Del Casal que, al igual que él, ella también sońó en una oportunidad con el mismo toro que acaban de encontrar y que fue después de eso que tuvo una vivencia que la hizo sentirse en peligro. La vergüenza invade de nuevo a Felipe Osuna cuando no puede responderle sexualmente a su esposa Antonieta como ha sucedido desde que se casaron; la muchacha indaga si por ese “problema” es que él la ha estado evitando quedarse a solas con ella; Felipe se molesta con la joven por sugerir algo semejante. Debido a la fuerte lluvia; Nicolás y Victoria se ven en la necesidad de refugiarse en un galpón abandonado en Cantarrana; lugar donde la joven Guanipa aprovecha para preguntarle a su amado por qué no insistió en reconciliarse con ella y terminó casándose con Florencia; él se limita a decirle que ya es muy tarde para preguntarse por qué pasaron las cosas que ya no tienen vuelta atrás." type="episode" duration="2571000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="98" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.wa