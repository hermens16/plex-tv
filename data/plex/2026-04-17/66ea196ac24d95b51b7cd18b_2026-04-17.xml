h4.com/1080/3/1672724.jpg" title="S01:E48" userState="0"><Image alt="S01:E48" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1672724.jpg"/><Image alt="S01:E48" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1672724.jpg"/><Image alt="S01:E48" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1672724.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1776400810" duration="4797000" endsAt="1776405607" id="69d79cef6ad16397528a862e" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1776422505" duration="3183000" endsAt="1776425688" id="69d9971c557ff6febb34d16f" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1776452137" duration="3049000" endsAt="1776455186" id="69d9971c557ff6febb34d179" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69d6f42d05ee582dd73bd6c6" key="/library/metadata/69d6f42d05ee582dd73bd6c6" ratingKey="69d6f42d05ee582dd73bd6c6" summary="Una vez en el funeral de Fernanda –quien prefirió suicidarse antes de ir a la cárcel- Leopoldo consuela a su hija menor Eugenia mientras que Antonieta se refugia en los brazos de Felipe; Caída la noche, Adelaida recibe la visita de Victoria, quien ha llegado a la capital para asistir a la boda de su madre; sin embargo, Adelaida y Hansen han decidido posponerla por respeto al luto de Victoria; en ese momento, la conversación entre madre e hija se ve interrumpida por la visita de Florencia, quien una vez a solas con Victoria le pide perdón por todo el dańo que le causó; Florencia le entrega a Victoria los anillos que Nicolás utilizaría en su matrimonio y que ahora podrá usar cuando Nicolás firme el divorcio. Con el paso de los días, Nicolás y Victoria contraen matrimonio ante un altar en compańía de sus familiares; allí, Hilario le entrega a su hija la hacienda Cantarrana y todas sus tierras como regalo de bodas. Clementina acepta casarse con Felipe, quien se sorprende cuando su amada le informa que pronto será papá. No muy lejos de allí, Florencia se reencuentra con Hilario Guanipa, quien desearía escaparse con ella, pero Florencia le pide acompańarla siempre. Los recién casados cabalgan por Cantarrana, donde Victoria y Nicolás se comprometen a luchar por el desarrollo de la hacienda y el crecimiento de su familia." type="episode" contentRating="NONADULT" duration="3045000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="130" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E130" userState="0"><Image alt="S01:E130" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E130" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E130" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1776385680" duration="3178000" endsAt="1776388858" id="69d79cef6ad16397528a8629" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69d79ceb6ad16397528a8609" key="/library/metadata/69d79ceb6ad16397528a8609" ratingKey="69d79ceb6ad16397528a8609" summary="Alfonso se presenta en el anticuario para solicitar los servicios de sicariato de Pedro. Luego de las sospechas iniciales por parte del delincuente, cuando éste se anima a hacer el negocio, el pánico invade al biólogo al comprobar que efectivamente está ante la presencia de un asesino - Alberto llega al encuentro de Lorena y, destrozado, le confía a su esposa que descubrió que el asesino de su padre es su tío Claudio. Lorena impactada y aterrada por el hallazgo de Alberto." type="episode" contentRating="NONADULT" duration="3245000" grandparentArt="https://cdn-images.watch4.com/1080/3/1673084.jpg" grandparentGuid="plex://show/68bad9a39aa661c3574d4960" grandparentKey="/library/metadata/68bad9a39aa661c3574d4960" grandparentRatingKey="68bad9a39aa661c3574d4960" grandparentThumb="https://cdn-images.watch4.com/1920/2/1673084.jpg" grandparentTitle="Corazon Traicionado" grandparentType="show" index="67" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1673084.jpg" title="Corazón Traicionado - S01:E67" userState="0"><Image alt="Corazón Traicionado - S01:E67" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E67" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E67" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1776382434" duration="3246000" endsAt="1776385680" id="69d79cef6ad16397528a8628" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1776405607" duration="3245000" endsAt="1776408852" id="69d9971c557ff6febb34d169" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1776434777" duration="3111000