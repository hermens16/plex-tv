rary/metadata/69b0b83aba3a6d319e0e710b" grandparentRatingKey="69b0b83aba3a6d319e0e710b" grandparentThumb="https://cdn-images.watch4.com/1920/2/1672730.jpg" grandparentTitle="Te Tengo en Salsa" grandparentType="show" index="61" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1672730.jpg" title="S01:E61" userState="0"><Image alt="S01:E61" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1672730.jpg"/><Image alt="S01:E61" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1672730.jpg"/><Image alt="S01:E61" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1672730.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1778925141" duration="2932000" endsAt="1778928073" id="69ffd21727f52460ad2782f0" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1778954627" duration="3066000" endsAt="1778957693" id="69ffd21727f52460ad2782fa" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69ffd21727f52460ad2782ea" key="/library/metadata/69ffd21727f52460ad2782ea" ratingKey="69ffd21727f52460ad2782ea" summary="Nicolás asegura a Victoria que, aunque vaya a casarse con Florencia y quiere tratar de amarla, no puede porque es de ella de quien él sigue enamorado. Florencia acusa sorpresa cuando Hilario se presenta ante ella con un ramo de flores y con la esperanza de que haya entendido que la vida la puso en su camino para que él pueda olvidarse de todo lo demás. Victoria no entiende la actitud de Nicolás; que insiste en que la ama, pero se va a casar con Florencia; a la joven Guanipa le parece un verdadero descaro del joven que le manifieste amor cuando está a punto de casarse con otra mujer a la que obviamente tampoco respeta. Florencia le insiste a Hilario en que no le hable de amor, pues ella se va a casar con Nicolás Del Casal, noticia que causa gran impresión al seńor Guanipa. Victoria le confía a Clementina que ya empezó a aceptar que Nicolás escogió a Florencia y no a ella para compartir su vida. Victoria, que no cree que Fernanda le devuelva Cantarrana, le ruega a Nicolás que no vaya a vivir a la que fue su casa con Florencia, quien aparece en ese momento y, aparte de advertirle a la joven Guanipa que ellos vivirán donde les parezca, la insta a entender de una vez que ella ya no cuenta para nada en la vida de Nicolás." type="episode" contentRating="NONADULT" duration="3083000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="80" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E080" userState="0"><Image alt="S01:E080" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E080" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E080" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1778937234" duration="3083000" endsAt="1778940317" id="69ffd21727f52460ad2782f4" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1778966855" duration="3082000" endsAt="1778969937" id="69ffd21727f52460ad2782fe" onAir="0" premiere="0" videoResolution="7