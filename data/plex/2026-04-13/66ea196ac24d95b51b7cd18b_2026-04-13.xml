43000" grandparentArt="https://cdn-images.watch4.com/1080/3/1672724.jpg" grandparentGuid="plex://show/66ea19708651b52ba9cee047" grandparentKey="/library/metadata/66ea19708651b52ba9cee047" grandparentRatingKey="66ea19708651b52ba9cee047" grandparentThumb="https://cdn-images.watch4.com/1920/2/1672724.jpg" grandparentTitle="Piel Salvaje" grandparentType="show" index="44" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1672724.jpg" title="S01:E44" userState="0"><Image alt="S01:E44" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1672724.jpg"/><Image alt="S01:E44" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1672724.jpg"/><Image alt="S01:E44" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1672724.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1776053393" duration="3144000" endsAt="1776056537" id="69d256ae8c1f6132b1aadd8e" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69d1ade89c21c35657b0dd3b" key="/library/metadata/69d1ade89c21c35657b0dd3b" ratingKey="69d1ade89c21c35657b0dd3b" summary="Por más que Hilario insiste en rehacer su vida junto a Florencia, ésta cree que aún existen cosas por perder antes de ser feliz al lado de Hilario Guanipa Ante Federico, Fernanda debe admitir que asesinó a Genara; a solas, Federico guarda la confesión de su madre que ha grabado en una cámara de video. Después de una semana, Victoria insiste en casarse con Sergio a pesar de que Adelaida y Clementina se niegan; si bien Victoria no ama a Sergio, necesita el apoyo de su madre para ser feliz; Adelaida no quiere que su hija cometa un error. Una vez en la jefatura civil, Carmencita trata de convencer a Victoria de cancelar su matrimonio, mientras que Hilario cree que Sergio obliga a Victoria a casarse; en ese momento, Nicolás se presenta en el lugar para manifestarle a Victoria que Sergio tiene negocios sórdidos con Fernanda, pero Victoria no le cree a Del Casal.Ante Fernanda, Sergio afirma tener su confesión sobre la muerte de Genara, por lo que Fernanda apunta al hombre con su arma; la pareja discute el arma se dispara; Florencia observa como Sergio –herido a muerte- sale del despacho." type="episode" contentRating="NONADULT" duration="2935000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="126" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E126" userState="0"><Image alt="S01:E126" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E126" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E126" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1776040976" duration="3068000" endsAt="1776044044" id="69d256ae8c1f6132b1aadd8a" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69d256aa8c1f6132b1aadd68" key="/library/metadata/69d256aa8c1f6132b1aadd68" ratingKey="69d256aa8c1f6132b1aadd68" summary="Lorena en shock ante el cuerpo sin vida de su comadre y amiga. Pedro, frío, la obliga a verlo a los ojos y le advierte que con un sicario no se juega; que la próxima vez que se le ocurra traicionarlo, la víctima será su hijo. El Juez Montilla afirma que dependiendo de lo que se discuta y los acuerdos a los que lleguen en esa audiencia, podrá revocar o no la libertad bajo fianza de Isabel." type="episode" contentRating="NONADULT" duration="3237000" grandparentArt="https://cdn-images.watch4.com/1080/3/1673084.jpg" grandparentGuid="plex://show/68bad9a39aa661c3574d4960" grandparentKey="/library/metadata/68bad9a39aa661c3574d4960" grandparentRatingKey="68bad9a39aa661c3574d4960" grandparentThumb="https://cdn-images.watch4.com/1920/2/1673084.jpg" grandparentTitle="Corazon Traicionado" grandparentType="show" index="63" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1673084.jpg" title="Corazón Traicionado - S01:E63" userState="0"><Image alt="Corazón Traicionado - S01:E63" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E63" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E63" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1776037738" duration="3238000" endsAt="1776040976" id="69d256ae8c1f6132b1aadd89" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1776060007" duration="3237000" endsAt="1776063244" id="69d4510f09c23231cbeef995" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1776090033" duration="3103000" endsAt="1776093136" id="69d4510f09c23231cbeef99f" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1776120732" duration="3237000" endsAt="1776123969" id="69d4510f09c23231cbeef9a9" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69d256ac8c1f6132b1aadd69" key="/library/metadata/69d256ac8c1f6132b1aadd69" ratingKey="69d256ac8c1f6132b1aadd69" summary="Victoria le confía a Jack que quiere irse del país para alejarse de tanto odio. Yosmir lleva a Eugenia a pasear en la moto en que Chabeto pretendía salir con las otras muchachas. Florencia piensa seguir adelante con su venganza contra Hilario aunque Nicolás no la ayude. Victoria sorprende a Jack asegurándole a Jonás que no piensa huir del país; la muchacha exige una explicación." type="episode" contentRating="NONADULT" duration="3083000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="46" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E046" userState="0"><Image alt="S01:E046" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E046" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E046" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1776083909" duration="3082000" endsAt="1776086991" id="69d4510f09c23231cbeef99d" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1776114742" duration="2949000" endsAt="1776117691" id="69d4510f09c23231cbeef9a7" onAir="0" premiere="0" video