<MediaContainer offset="0" totalSize="13" identifier="tv.plex.provider.epg" size="13"><Video guid="plex://episode/69c5d07849cda1982c410179" key="/library/metadata/69c5d07849cda1982c410179" ratingKey="69c5d07849cda1982c410179" summary="En una entrega de amor, Victoria y Nicolás prometen amarse siempre y renuncian a todo aquello que pueda perturbar su felicidad. Ahora que espera un hijo de Nicolás, Florencia no permitirá que Victoria se interponga en su matrimonio y así se lo hace saber a Adelaida, quien la echa de su casa mientras que Hilario no puede creer que su amada espere un hijo de otro hombre. Nicolás le asegura a Florencia responder por su hijo, pero no puede seguir atado a ella. Nicolás visita a Victoria para manifestarle su decisión de seguir junto a ella y su hijo porque no puede seguir atado a Florencia, pero Victoria le hace saber que ella no puede aceptar alejarlo de la mujer que espera un hijo de él." type="episode" contentRating="NONADULT" duration="2922000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="117" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E117" userState="0"><Image alt="S01:E117" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E117" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E117" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1775263338" duration="3055000" endsAt="1775266393" id="69c6794774f31a68d329c83c" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69c5d07a49cda1982c41017b" key="/library/metadata/69c5d07a49cda1982c41017b" ratingKey="69c5d07a49cda1982c41017b" summary="Ignorando la frialdad de Adriana, Carlos confiesa a la chef que está enamorado y la reta a negar que ella siente lo mismo por él." type="episode" contentRating="NONADULT" duration="2963000" grandparentArt="https://cdn-images.watch4.com/1080/3/1672730.jpg" grandparentGuid="plex://show/69b0b83aba3a6d319e0e710b" grandparentKey="/library/metadata/69b0b83aba3a6d319e0e710b" grandparentRatingKey="69b0b83aba3a6d319e0e710b" grandparentThumb="https://cdn-images.watch4.com/1920/2/1672730.jpg" grandparentTitle="Te Tengo en Salsa" grandparentType="show" index="17" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1672730.jpg" title="S01:E17" userState="0"><Image alt="S01:E17" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1672730.jpg"/><Image alt="S01:E17" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1672730.jpg"/><Image alt="S01:E17" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1672730.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1775269413" duration="3225000" endsAt="1775272638" id="69c6794774f31a68d329c83e" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69c6794374f31a68d329c819" key="/library/metadata/69c6794374f31a68d329c819" ratingKey="69c6794374f31a68d329c819" summary="Malena habla presurosa pidiendo ayuda a Isabel ante un nuevo ataque de Pablo; al descubrirla, éste le arrebata el móvil, lo lanza contra el piso e intenta agredirla ferozmente. Ella se defiende empujándolo con todas sus fuerzas, el hombre pierde el equilibrio, no encuentra de donde sujetarse, y cae al vacío desde el balcón. Malena aterrada, en shock." type="episode" contentRating="NONADULT" duration="3241000" grandparentArt="https://cdn-images.watch4.com/1080/3/1673084.jpg" grandparentGuid="plex://show/68bad9a39aa661c3574d4960" grandparentKey="/library/metadata/68bad9a39aa661c3574d4960" grandparentRatingKey="68bad9a39aa661c3574d4960" grandparentThumb="https://cdn-images.watch4.com/1920/2/1673084.jpg" grandparentTitle="Corazon Traicionado" grandparentType="show" index="54" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1673084.jpg" title="Corazón Traicionado - S01:E54" userState="0"><Image alt="Corazón Traicionado - S01:E54" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E54" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E54" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1775260096" duration="3242000" endsAt="1775263338" id="69c6794774f31a68d329c83b" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1775282407" duration="3241000" endsAt="1775285648" id="69c87366d0fab9f753c564fe" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1775312367" duration="3107000" endsAt="1775315474" id="69c87366d0fab9f753c56508" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1775343044" duration="3241000" endsAt="1775346285" id="69c87366d0fab9f753c56512" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69c6794574f31a68d329c81a" key="/library/metadata/69c6794574f31a68d329c81a" ratingKey="69c6794574f31a68d329c81a" summary="Negado a aceptar la decisión de Victoria de alejarse de él ahora que será padre del hijo que espera Florencia; Nicolás trata de convencer a su amada de confiar en que es posible estar juntos. Florencia se presenta en casa de Victoria para saber si ésta es capaz de seguir junto a Nicolás a pesar de su estado; una vez que Nicolás llega al lugar, Florencia se impone en defensa de su amor por el padre de su hijo.Ante el desánimo que embarga a Victoria, Hilario se desahoga con Adelaida, pues teme no poder proteger a su hija del sufrimiento que le causa la noticia del embarazo de Florencia;" type="episode" contentRating="NONADULT" duration="2504000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="118" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E118" userState="0"><Image alt="S01:E118" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E118" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E118" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1775266393" duration="3020000" endsAt="1775269413" id="69c6794774f31a68d329c83d" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1775288862" duration="2887000" endsAt="1775291749" id="69c87366d0fab9f753c56500" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1775318688" duration="2886000" endsAt="1775321574" id="69c87366d0fab9f753c5650a" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69c6794574f31a68d329c81b" key="/library/metadata/69c6794574f31a68d329c81b" ratingKey="69c6794574f31a68d329c81b" summary="Eugenia se disculpa con Yosmir por la forma en que lo trató frente a sus amigas y le explica sus motivos; el jovencito considera que si para ella es tan complicado estar con él debería pensarlo mejor. Hilario no quiere darle información a Florencia sobre el ”negro Quijada”, pero la muchacha le asegura que su intención es sólo pedirle disculpas al familia del hombre como Rosendo le encomendó. Hilario está tratando de convencer a Adelaida de que está feliz por su regreso a Cantarrana cuando recibe una llamada de Florencia pidiéndole que vuelvan a verse. Clementina coquetea con Jonás para molestar a Antonieta y Felipe le reclama; el joven Osuna se desconcierta cuando la muchacha sugiere que está celoso. Jack se complace cuando Victoria le pide que le tenga paciencia y espere por ella." type="episode" contentRating="NONADULT" duration="3071000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="37" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E037" userState="0"><Image alt="S01:E037" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt