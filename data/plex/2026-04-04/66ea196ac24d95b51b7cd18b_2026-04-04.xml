genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1775272638" duration="3104000" endsAt="1775275742" id="69c6794774f31a68d329c83f" onAir="1" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1775294214" duration="2963000" endsAt="1775297177" id="69c87366d0fab9f753c56502" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1775324623" duration="3097000" endsAt="1775327720" id="69c87366d0fab9f753c5650c" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69c6794774f31a68d329c81d" key="/library/metadata/69c6794774f31a68d329c81d" ratingKey="69c6794774f31a68d329c81d" summary="Camila se defiende fieramente de la agresión de Roberto y le cuenta a Max lo sucedido. La Madre Isabel, para ayudar a Camila, le confía a Ezequiel el motivo por el que Roberto la extorsiona. Max presiona a Camila para que le cuente toda la verdad." type="episode" contentRating="NONADULT" duration="3124000" grandparentArt="https://cdn-images.watch4.com/1080/3/1672724.jpg" grandparentGuid="plex://show/66ea19708651b52ba9cee047" grandparentKey="/library/metadata/66ea19708651b52ba9cee047" grandparentRatingKey="66ea19708651b52ba9cee047" grandparentThumb="https://cdn-images.watch4.com/1920/2/1672724.jpg" grandparentTitle="Piel Salvaje" grandparentType="show" index="35" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1672724.jpg" title="S01:E35" userState="0"><Image alt="S01:E35" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1672724.jpg"/><Image alt="S01:E35" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1672724.jpg"/><Image alt="S01:E35" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1672724.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1775275742" duration="3125000" endsAt="1775278867" id="69c6794774f31a68d329c840" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69c6794774f31a68d329c81e" key="/library/metadata/69c6794774f31a68d329c81e" ratingKey="69c6794774f31a68d329c81e" summary="Roberto confiesa que fue él quien asesinó a Gabriel para inculpar a Camila. Camila, llora de alegría, al saberse inocente de esa muerte. Max le reitera su incondicional apoyo ratificándole su gran amor. Ezequiel expresa su intención de casarse con Camila" type="episode" contentRating="NONADULT" duration="3050000" grandparentArt="https://cdn-images.watch4.com/1080/3/1672724.jpg" grandparentGuid="plex://show/66ea19708651b52ba9cee047" grandparentKey="/library/metadata/66ea19708651b52ba9cee047" grandparentRatingKey="66ea19708651b52ba9cee047" grandparentThumb="https://cdn-images.watch4.com/1920/2/1672724.jpg" grandparentTitle="Piel Salvaje" grandparentType="show" index="36" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1672724.jpg" title="S01:E36" userState="0"><Image alt="S01:E36" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1672724.jpg"/><Image alt="S01:E36" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1672724.jpg"/><Image alt="S01:E36" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1672724.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1775278867" duration="3540000" endsAt="1775282407" id="69c6794774f31a68d329c841" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1775300143" duration="3184000" endsAt="1775303327" id="69c87366d0fab9f753c56504" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1775330819" duration="3051000" endsAt="1775333870" id="69c87366d0fab9f753c5650e" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69c8735dd0fab9f753c564e7" key="/library/metadata/69c8735dd0fab9f753c564e7" ratingKey="69c8735dd0fab9f753c564e7" summary="Gertrudis le expone a Alberto su teoría de lo ocurrido: Malena e Isabel planearon la muerte de Pablo para quitarlo del medio, ya que se resistía a firmar el divorcio. El momento de la verdad llega; Omar se presenta ante la enfermera y le hace saber que descubrió su secreto: ella era la mujer del sicario que asesinó a Marco Aurelio Corona; a Lorena se le viene el mundo encima." type="episode" contentRating="NONADULT" duration="3214000" grandparentArt="https://cdn-images.watch4.com/1080/3/1673084.jpg" grandparentGuid="plex://show/68bad9a39aa661c3574d4960" grandparentKey="/library/metadata/68bad9a39aa661c3574d4960" grandparentRatingKey="68bad9a39aa661c3574d4960" grandparentThumb="https://cdn-images.watch4.com/1920/2/1673084.jpg" grandparentTitle="Corazon Traicionado" grandparentType="show" index="55" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1673084.jpg" title="Corazón Traicionado - S01:E55" userState="0"><Image alt="Corazón Traicionado - S01:E55" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E55" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E55" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1775285648" duration="3214000" endsAt="1775288862" id="69c87366d0fab9f753c564ff" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1775315474" duration="3214000" endsAt="1775318688" id="69c87366d0fab9f753c56509" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1775346285" duration="3214000" endsAt="1775349499" id="69c87366d0fab9f753c56513" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69c87361d0fab9f753c564e8" key="/library/metadata/69c87361d0fab9f753c564e8" ratingKey="69c87361d0fab9f753c564e8" summary="Convencida de que su hijo cumplió con su parte del trato en la guerra contra los Guanipa, Fernanda le pide a Federico regresar a la capital, pero el joven Alcoy no se marchará de la hacienda no sin antes conseguir sus objetivos. En medio de una cena romántica, Nicolás no tiene ninguna duda de que Victoria Guanipa será su esposa; una enamorada Victoria lo besa. Después de una noche junto a Nicolás, Victoria se siente culpable de amar a un hombre que espera un hijo de Florencia. A escondidas, Genara escucha cuando Sergio lamenta haber perdido la oportunidad de matar a Nicolás. Por su parte, Nicolás se desahoga con su tío, pues – a pesar de no estar enamorado de Florencia - Nicolás necesita que la madre de su hijo sea feliz. Justo cuando Sergio toma del brazo a Genara para asegurarse de que la chica no lo haya escuchado, Federico defiende a Genara; una vez a solas con el joven Alcoy, Genara le pide no acercarse más a ella, pues su vida corre peligro ahora que está en medio de la guerra entre los Del Casal y los Guanipa." type="episode" contentRating="NONADULT" duration="2465000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="119" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E119" userState="0"><Image alt="S01:E119" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E119" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E119" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1775291749" duration="2465000" endsAt="1775294214" id="69c87366d0fab9f753c56501" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1775321574" duration="3049000" endsAt="1775324623" id="69c87366d0fab9f753c5650b" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69c87361d0fab9f753c564e9" key="/library/metadata/69c87361d0fab9f753c564e9" ratingKey="69c87361d0fab9f753c564e9" summary="Nicolás quiere que Sigfrido lo ayude a ponerle una flor en la habitación todos los días a Victoria; el joven Del Casal acusa sorpresa cuando el nińo le comenta que acaba de ver a Jack dándole un beso a Victoria. Victoria le comenta a Hilario sobre los papeles y las fotos que Nicolás encontró en Los Samanes y que ella destruyó al quemar la casa; la muchacha asegura a su padre ya se convenció de que nunca más puede creer en Nicolás. Hansen indaga con Felipe quién es Jack Builder, pues le llama la atención que el hombre estuvo haciéndole varias preguntas sobre Hilario a alguien con quien Guanipa está por cerrar un negocio. Adelaida se llena de indignación cuando Genara le cuenta que Hilario se fue en la avioneta y no está en la hacienda como le aseguró. Antonieta no quiere que Felipe se case con Clementina, pero se niega a aceptar que es porque el muchacho le importa." type="episode" contentRating="NONADULT" duration="3051000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="38" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E038" userState="0"><Image alt="S01:E038" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E038" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E038" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1775309316" duration="3051000" endsAt="1775312367" id="69c87366d0fab9f753c56507" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1775339994" duration="3050000" endsAt="1775343044" id="69c87366d0fab9f753c56511" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69c87363d0fab9f753c564fc" key="/library/metadata/69c87363d0fab9f753c564fc" ratingKey="69c87363d0fab9f753c564fc" summary="Carlos esta esperando en casa de Palacios, en el momento que Patricia sale con Tatiana. Patricia pregunta qué hace C.R. Perroni en su hogar y Adriana indaga de dónde se conocen." type="episode" contentRating="NONADULT" duration="2966000" grandparentArt="https://cdn-images.watch4.com/1080/3/1672730.jpg" grandparentGuid="plex://show/