<MediaContainer offset="0" totalSize="8" identifier="tv.plex.provider.epg" size="8"><Video guid="plex://episode/69b8a0afe3773dd6cdb59033" key="/library/metadata/69b8a0afe3773dd6cdb59033" ratingKey="69b8a0afe3773dd6cdb59033" summary="Só a Madre Isabel está convencida da atitude nobre da sua menina, que desiste das suas intençőes de cobrar a traiçăo ŕs tręs mulheres e até lhes pede perdăo. Ezequiel conta a Camila o noivado do filho e ela censura-o por ter ido tăo depressa, esquecendo o grande amor que dizia ter por ela." type="episode" contentRating="NONADULT" duration="3292000" grandparentArt="https://d3dpwvkv1y8pcn.cloudfront.net/Images/S3/WAPIS/272_1672724.jpg" grandparentGuid="plex://show/687fff08c082969749e5c0d6" grandparentKey="/library/metadata/687fff08c082969749e5c0d6" grandparentRatingKey="687fff08c082969749e5c0d6" grandparentThumb="https://d3dpwvkv1y8pcn.cloudfront.net/Images/S3/WAPIS/wedotv_amor_piel_salvaje20251_1672466-portrait.jpg" grandparentTitle="Piel Salvaje" grandparentType="show" index="72" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://d3dpwvkv1y8pcn.cloudfront.net/Images/S3/WAPIS/272_1672724.jpg" title="S01E072" userState="0"><Image alt="S01E072" type="coverArt" url="https://d3dpwvkv1y8pcn.cloudfront.net/Images/S3/WAPIS/272_1672724.jpg"/><Image alt="S01E072" type="coverPoster" url="https://d3dpwvkv1y8pcn.cloudfront.net/Images/S3/WAPIS/wedotv_amor_piel_salvaje20251_1672466-portrait.jpg"/><Image alt="S01E072" type="snapshot" url="https://d3dpwvkv1y8pcn.cloudfront.net/Images/S3/WAPIS/272_1672724.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1774745588" duration="3292000" endsAt="1774748880" id="69c6788b74f31a68d329c124" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://ep