="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1775105873" duration="3734000" endsAt="1775109607" id="69c3d65be9b8a8c5e1cc800f" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1775127375" duration="3037000" endsAt="1775130412" id="69c5d07c49cda1982c410183" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1775157953" duration="2903000" endsAt="1775160856" id="69c5d07c49cda1982c41018d" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69c5d07449cda1982c410178" key="/library/metadata/69c5d07449cda1982c410178" ratingKey="69c5d07449cda1982c410178" summary="Malena habla presurosa pidiendo ayuda a Isabel ante un nuevo ataque de Pablo; al descubrirla, éste le arrebata el móvil, lo lanza contra el piso e intenta agredirla ferozmente. Ella se defiende empujándolo con todas sus fuerzas, el hombre pierde el equilibrio, no encuentra de donde sujetarse, y cae al vacío desde el balcón. Malena aterrada, en shock." type="episode" contentRating="NONADULT" duration="3209000" grandparentArt="https://cdn-images.watch4.com/1080/3/1673084.jpg" grandparentGuid="plex://show/68bad9a39aa661c3574d4960" grandparentKey="/library/metadata/68bad9a39aa661c3574d4960" grandparentRatingKey="68bad9a39aa661c3574d4960" grandparentThumb="https://cdn-images.watch4.com/1920/2/1673084.jpg" grandparentTitle="Corazon Traicionado" grandparentType="show" index="53" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1673084.jpg" title="Corazón Traicionado - S01:E53" userState="0"><Image alt="Corazón Traicionado - S01:E53" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E53" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E53" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1775112797" duration="3209000" endsAt="1775116006" id="69c5d07c49cda1982c41017e" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1775142579" duration="3209000" endsAt="1775145788" id="69c5d07c49cda1982c410188" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1775173291" duration="3210000" endsAt="1775176501" id="69c5d07c49cda1982c410192" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69c5d07849cda1982c410179" key="/library/metadata/69c5d07849cda1982c410179" ratingKey="69c5d07849cda1982c410179" summary="En una entrega de amor, Victoria y Nicolás prometen amarse siempre y renuncian a todo aquello que pueda perturbar su felicidad. Ahora que espera un hijo de Nicolás, Florencia no permitirá que Victoria se interponga en su matrimonio y así se lo hace saber a Adelaida, quien la echa de su casa mientras que Hilario no puede creer que su amada espere un hijo de otro hombre. Nicolás le asegura a Florencia responder por su hijo, pero no puede seguir atado a ella. Nicolás visita a Victoria para manifestarle su decisión de seguir junto a ella y su hijo porque no puede seguir atado a Florencia, pero Victoria le hace saber que ella no puede aceptar alejarlo de la mujer que espera un hijo de él." type="episode" contentRating="NONADULT" duration="2527000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="117" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E117" userState="0"><Image alt="S01:E117" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E117" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E117" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1775118934" duration="2527000" endsAt="1775121461" id="69c5d07c49cda1982c410180" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1775148716" duration="3055000" endsAt="1775151771" id="69c5d07c49cda1982c41018a" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69c5d07849cda1982c41017a" key="/library/metadata/69c5d07849cda1982c41017a" ratingKey="69c5d07849cda1982c41017a" summary="Nicolás percibe que hay algo que perturba a Eugenia pero, en vista de que ella se niega a confiarle el motivo de su pena, se limita a aconsejarle que luche por su amor sin tener miedo. Victoria pide a Jack la ayude a demostrarle a Nicolás que ella puede estar sin él; el actor acepta ser utilizado, porque sabe que eso lo ayudará a estar cerca de ella. A Leopoldo le hace gracia que Fernanda esté pensando que la está engańando con otra mujer cuando lo único de lo que se ocupa es de su venganza contra Hilario. Ya en la fiesta, Nicolás comparte con Liliana cuando ve que Victoria llega del brazo de Jack Builder; la joven Guanipa no duda en acercarse a Del Casal para asegurarle que él ya desapareció de su vida para siempre." type="episode" duration="3068000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="35" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E035 - Episodio 35" userState="0"><Image alt="S01:E035 - Episodio 35" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E035 - Episodio 35" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E035 - Episodio 35" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1775136455" duration="3068000" endsAt="1775139523" id="69c5d07c49cda1982c410186" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1775167034" duration="3067000" endsAt="1775170101" id="69c5d07c49cda1982c410190" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69c5d07a49cda1982c41017b" key="/library/metadata/69c5d07a49cda1982c41017b" ratingKey="69c5d07a49cda1982c41017b" summary="Ignorando la frialdad de Adriana, Carlos confiesa a la chef que está enamorado y la reta a negar que ella siente lo mismo por él." type="episode" contentRating="NONADULT" duration="2964000" grandparentArt="https://cdn-images.watch4.com/1080/3/1672730.jpg" grandparentGuid="plex://show/69b0b83aba3a6d319e0e710b" grandparentKey="/library/metadata/69b0b83aba3a6d319e0e710b" grandparentRatingKey="69b0b83aba3a6d319e0e710b" grandparentThumb="https://cdn-images.watch4.com/1920/2/1672730.jpg" grandparentTitle="Te Tengo en Salsa" grandparent