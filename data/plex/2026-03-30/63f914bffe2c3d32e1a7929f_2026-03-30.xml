dfront.net/thumbnails-platform-prod/assets/cs::content::shows/11056-13104/22644294-default_v1.jpeg" grandparentGuid="plex://show/6489b1f1782e547231bd91c4" grandparentKey="/library/metadata/6489b1f1782e547231bd91c4" grandparentRatingKey="6489b1f1782e547231bd91c4" grandparentThumb="https://provider-static.plex.tv/epg/cms/production/e82ff7c4-015e-440d-a8df-d960efc5d3f8/GLORY_2000x3000_Nicholas_Olsen.jpg" grandparentTitle="GLORY Kickboxing" grandparentType="show" index="9" originallyAvailableAt="2025-12-17T17:16:14Z" parentIndex="0" requiresConsent="1" skipParent="1" thumb="https://partner-upload-assets.wurl.com/glory_kickboxing/FAST_Graphics_C8.jpg" title="COLLISION 8" userState="0" year="2025"><Image alt="COLLISION 8" type="coverArt" url="https://dki01q1l7yn3y.cloudfront.net/thumbnails-platform-prod/assets/cs::content::shows/11056-13104/22644294-default_v1.jpeg"/><Image alt="COLLISION 8" type="coverPoster" url="https://provider-static.plex.tv/epg/cms/production/e82ff7c4-015e-440d-a8df-d960efc5d3f8/GLORY_2000x3000_Nicholas_Olsen.jpg"/><Image alt="COLLISION 8" type="snapshot" url="https://partner-upload-assets.wurl.com/glory_kickboxing/FAST_Graphics_C8.jpg"/><Genre filter="genre=620143f98578b9238e1cdb8a" id="620143f98578b9238e1cdb8a" key="/library/sections/home/all?genre=620143f98578b9238e1cdb8a" ratingKey="genre_620143f98578b9238e1cdb8a" slug="sports" tag="Sports" type="directory" context="tag.genre"/><Media beginsAt="1774814149" duration="21708000" endsAt="1774835857" id="69c133515a85056019e4ce13" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69bfe14550c30c62fc643fd8" key="/library/metadata/69bfe14550c30c62fc643fd8" ratingKey="69bfe14550c30c62fc643fd8" summary="Four more will punch their tickets into the next round as GLORY &amp; RISE search for the baddest featherweight on the planet in this year long tournament. On the GLORY side, top ranked German Polish fighter Denis Wosik (40-9-1, 9 KO) takes on Thai veteran Suarek (107-40-11, 39 KO) and Italy’s Achraf Aasila (53-13, 13 KO) meets France’s Lounis Saing (19-4-1, 12 KO). Meanwhile on the RISE side of the bracket, Japan’s Yutaro Asahi (17-9, 4 KO) clashes with Spain’s Eduardo Catalin (17-3-1) and top Japanese prospect Yura Kono (15-1, 7 KO) goes up against China’s Dexiang Kong (35-10). In addition to the Last Featherweight Standing matchups, Shiro Matsumoto (53-17-4, 18 KO) defends his RISE bantamweight title against top challenger Masahi Kumura (24-7, 12 KO) and Australian KO artists Chadd Collins (64-18-2, 32) defends his RISE super lightweight championship against the great Kento Haraguchi (25-4-1, 14 KO)." type="episode" contentRating="PG-13" duration="13399000" grandparentArt="https://dki01q1l7yn3y.cloudfront.net/thumbnails-platform-prod/assets/cs::content::shows/11056-13104/22644294-default_v1.jpeg" grandparentGuid="plex://show/6489b1f1782e547231bd91c4" grandparentKey="/library/metadata/6489b1f1782e547231bd91c4" grandparentRatingKey="6489b1f1782e547231bd91c4" grandparentThumb="https://provider-static.plex.tv/epg/cms/production/e82ff7c4-015e-440d-a8df-d960efc5d3f8/GLORY_2000x3000_Nicholas_Olsen.jpg" grandparentTitle="GLORY Kickboxing" grandparentType="show" index="7" originallyAvailableAt="2025-02-08T00:00:00Z" parentIndex="0" requiresConsent="1" skipParent="1" thumb="https://partner-upload-assets.wurl.com/glory_kickboxing/FAST_Graphics_G102.jpg" title="GLORY 102 Featherweight Grand Prix" userState="0" year="2025"><Image alt="GLORY 102 Featherweight Grand Prix" type="coverArt" url="https://dki01q1l7yn3y.cloudfront.net/thumbnails-platform-prod/assets/cs::content::shows/11056-13104/22644294-default_v1.jpeg"/><Image alt="GLORY 102 Featherweight Grand Prix" type="coverPoster" url="https://provider-static.plex.tv/epg/cms/production/e82ff7c4-015e-440d-a8df-d960efc5d3f8/GLORY_2000x3000_Nicholas_Olsen.jpg"/><Image alt="GLORY 102 Featherweight Grand Prix" type="snapshot" url="https://partner-upload-assets.wurl.com/glory_kickboxing