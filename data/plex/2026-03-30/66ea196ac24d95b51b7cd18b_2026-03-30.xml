<MediaContainer offset="0" totalSize="13" identifier="tv.plex.provider.epg" size="13"><Video guid="plex://episode/69bbed0199da3ffc7c54262b" key="/library/metadata/69bbed0199da3ffc7c54262b" ratingKey="69bbed0199da3ffc7c54262b" summary="Max y Ezequiel se enfrentan por Camila. Astrid trata de manipular a Roberto para sacarle información a cambio de dinero. Max acusa a Camila de prostituta y decide sacarla de su vida. El regreso de Rosa Blanco es traumático." type="episode" contentRating="NONADULT" duration="3081000" grandparentArt="https://cdn-images.watch4.com/1080/3/1672724.jpg" grandparentGuid="plex://show/66ea19708651b52ba9cee047" grandparentKey="/library/metadata/66ea19708651b52ba9cee047" grandparentRatingKey="66ea19708651b52ba9cee047" grandparentThumb="https://cdn-images.watch4.com/1920/2/1672724.jpg" grandparentTitle="Piel Salvaje" grandparentType="show" index="28" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1672724.jpg" title="S01:E28" userState="0"><Image alt="S01:E28" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1672724.jpg"/><Image alt="S01:E28" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1672724.jpg"/><Image alt="S01:E28" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1672724.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1774842970" duration="2955000" endsAt="1774845925" id="69c08a4b609be2e3137e2451" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69bde774d7287daa104f9588" key="/library/metadata/69bde774d7287daa104f9588" ratingKey="69bde774d7287daa104f9588" summary="Max decide enfrentar a Roberto, y cede a la seducción de Astrid, pero no por amor sino por despecho. Durante una cena familiar, Ezequiel brinda por Octavia, pero expresa su intención de casarse con otra mujer. Camila sabe que su madre regresará." type="episode" contentRating="NONADULT" duration="2927000" grandparentArt="https://cdn-images.watch4.com/1080/3/1672724.jpg" grandparentGuid="plex://show/66ea19708651b52ba9cee047" grandparentKey="/library/metadata/66ea19708651b52ba9cee047" grandparentRatingKey="66ea19708651b52ba9cee047" grandparentThumb="https://cdn-images.watch4.com/1920/2/1672724.jpg" grandparentTitle="Piel Salvaje" grandparentType="show" index="29" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1672724.jpg" title="S01:E29" userState="0"><Image alt="S01:E29" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1672724.jpg"/><Image alt="S01:E29" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1672724.jpg"/><Image alt="S01:E29" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1672724.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1774845925" duration="4482000" endsAt="1774850407" id="69c08a4b609be2e3137e2452" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774868098" duration="3061000" endsAt="1774871159" id="69c133d85a85056019e4d71a" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774898483" duration="2927000" endsAt="1774901410" id="69c133d85a85056019e4d724" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69be9017fff63a00989e8f7b" key="/library/metadata/69be9017fff63a00989e8f7b" ratingKey="69be9017fff63a00989e8f7b" summary="Una gran sorpresa se lleva Victoria cuando el secuestrador le afirma que Nicolás Del Casal intenta rescatarla; un furioso Sergio trata de convencer a Victoria de no creer en la información del delincuente. Convencido de rescatar a Victoria, Nicolás ha preparado un plan para salvar a Victoria si no se hace efectivo el rescate, y así se lo manifiesta a Felipe. Ante la llegada de Hilario y Moncho a Cantarrana, Adelaida pregunta por su hija y teme lo peor, pues no se pudo efectuar el rescate. Cuando el otro hombre que vigilaba a Victoria decide ir en busca de su compańero, Sergio lo apunta con un arma y libera a Victoria; al escapar del yugo de los delincuentes, Victoria desea descubrir quien está detrás del rapto. Un angustiado Felipe comenta las intenciones de Nicolás de rescatar a Victoria, mientras esta última se sorprende; Felipe defiende a Nicolás, quien arriesgó su vida para salvar a Victoria. Entre tanto, en el hospital, Florencia alienta a su esposo para que despierte; Nicolás abre sus ojos y lo primero que pregunta es si la policía pudo detener a los secuestradores y si su amada Victoria fue liberada." type="episode" contentRating="NONADULT" duration="2915000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="112" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E112" userState="0"><Image alt="S01:E112" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E112" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E112" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1774830754" duration="3048000" endsAt="1774833802" id="69c08a4b609be2e3137e244d" onAir="1" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69be9017fff63a00989e8f7c" key="/library/metadata/69be9017fff63a00989e8f7c" ratingKey="69be9017fff63a00989e8f7c" summary="Victoria trata de hacerle entender a Hilario que ella y Nicolás se aman sin importarle los odios del pasado entre su familia. Isaura y Carmencita están decididas a buscar la manera de convencer a Adelaida de que el verdadero Hilario no es el que le escribe las cartas. Yosmir le hace creer a Isaura que está saliendo con la hija del dueńo de la carnicería para conseguir que la seńora le preste dinero. Victoria asegura a Nicolás que no volverá a creer en sus mentiras, pues ya leyó todos sus correos y descubrió su plan; él aunque no entiende de qué le habla, le ruega que no se deje engańar por Hilario y sigan adelante con su idea de casarse; ella decide quemar Los Samanes e insta a Nicolás a marcharse de Cantarrana en la avioneta que le tiene preparada, pues ella está decidida a matar el amor que siente por él para siempre. Adelaida admite ante Carmencita que debe reconocer que Hilario nunca va a dejar de hacerla sufrir, pero ella tampoco va a dejar de amarlo." type="episode" contentRating="NONADULT" duration="3080000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="31" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E031" userState="0"><Image alt="S01:E031" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E031" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E031" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1774874026" duration="3079000" endsAt="1774877105" id="69c133d85a85056019e4d71c" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774904545" duration="2946000" endsAt="1774907491" id="69c133d85a85056019e4d726" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69be901afff63a00989e8f7d" key="/library/metadata/69be901afff63a00989e8f7d" ratingKey="69be901afff63a00989e8f7d" summary="Finalizado el espectáculo, Adriana llora al recordar que quiso ser bailarina pero no pudo por la humildad de su familia; César, conmovido, siente que la ama cada vez más." type="episode" contentRating="NONADULT" duration="2941000" grandparentArt="https://cdn-images.watch4.com/1080/3/1672730.jpg" grandparentGuid="plex://show/69b0b83aba3a6d319e0e710b" grandparentKey="/library/metadata/69b0b83aba3a6d319e0e710b" grandparentRatingKey="69b0b83aba3a6d319e0e710b" grandparentThumb="https://cdn-images.watch4.com/1920/2/1672730.jpg" grandparentTitle="Te Tengo en Salsa" grandparentType="show" index="12" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1672730.jpg" title="S01:E12" userState="0"><Image alt="S01:E12" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1672730.jpg"/><Image alt="S01:E12" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1672730.jpg"/><Image alt="S01:E12" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1672730.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1774836857" duration="3069000" endsAt="1774839926" id="69c08a4b609be2e3137e244f" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69c08a48609be2e3137e2434" key="/library/metadata/69c08a48609be2e3137e2434" ratingKey="69c08a48609be2e3137e2434" summary="Pablo manipula a Malena con el arma y la obliga a decirle que lo ama. Patricia y Lorena tocan a la puerta esperando que Malena les abra, pero ésta, apuntada con el arma por Pablo, les pide que se vayan; es obvio que él la forzó sexualmente una vez más. Magda, aterrada, le confía a Lorena que Pedro Lobo la amenazó de muerte a causa del video donde ella confiesa todo sobre el crimen de Marco Aurelio." type="episode" contentRating="NONADULT" duration="3174000" grandparentArt="https://cdn-images.watch4.com/1080/3/1673084.jpg" grandparentGuid="plex://show/68bad9a39aa661c3574d4960" grandparentKey="/library/metadata/68bad9a39aa661c3574d4960" grandparentRatingKey="68bad9a39aa661c3574d4960" grandparentThumb="https://cdn-images.watch4.com/1920/2/1673084.jpg" grandparentTitle="Corazon Traicionado" grandparentType="show" index="49" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1673084.jpg" title="Corazón Traicionado - S01:E49" userState="0"><Image alt="Corazón Traicionado - S01:E49" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E49" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E49" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1774827579" duration="3175000" endsAt="1774830754" id="69c08a4b609be2e3137e244c" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774850407" duration="3174000" endsAt="1774853581" id="69c133d85a85056019e4d714" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774880153" duration="3040000" endsAt="1774883193" id="69c133d85a85056019e4d71e" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774910538" duration="3174000" endsAt="1774913712" id="69c133d85a85056019e4d728" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69c08a49609be2e3137e2435" key="/library/metadata/69c08a49609be2e3137e2435" ratingKey="69c08a49609be2e3137e2435" summary="Justo cuando Victoria le impide a Sergio anunciar su compromiso frente a la familia Guanipa, Sergio cree que la mujer se arrepintió; Victoria es quien anuncia su matrimonio, lo que sorprende a todos. Adelaida en compańía de Hansen, recuerda la nińez de su hija Victoria, quien desde pequeńa ha sido traviesa; la sensación de tener a su hija en peligro y no poder hacer nada despertó en ella un sentimiento más grande. Victoria evita los besos de Sergio, quien se apresura por ponerle fecha a su matrimonio; Sergio ya ha preparado todo para casarse en una semana." type="episode" contentRating="NONADULT" duration="2477000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="113" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E113" use