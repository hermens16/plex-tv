ter" url="https://cdn-images.watch4.com/1920/2/1672730.jpg"/><Image alt="S01:E13" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1672730.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1774839926" duration="3044000" endsAt="1774842970" id="69c08a4b609be2e3137e2450" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774862202" duration="2943000" endsAt="1774865145" id="69c133d85a85056019e4d718" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774892319" duration="3077000" endsAt="1774895396" id="69c133d85a85056019e4d722" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69c133d35a85056019e4d6b3" key="/library/metadata/69c133d35a85056019e4d6b3" ratingKey="69c133d35a85056019e4d6b3" summary="Alfonso advierte que es posible que Lorena conozca a los autores intelectuales del asesinato de Marco Aurelio, y que su vida podría estar en peligro- Lorena va con Magda al anticuario a prometerle a Pedro que ellas nunca dirán nada de lo que saben, para que les perdone la vida; pero para su sorpresa Omar se presenta en la tienda y las descubre." type="episode" contentRating="NONADULT" duration="3133000" grandparentArt="https://cdn-images.watch4.com/1080/3/1673084.jpg" grandparentGuid="plex://show/68bad9a39aa661c3574d4960" grandparentKey="/library/metadata/68bad9a39aa661c3574d4960" grandparentRatingKey="68bad9a39aa661c3574d4960" grandparentThumb="https://cdn-images.watch4.com/1920/2/1673084.jpg" grandparentTitle="Corazon Traicionado" grandparentType="show" index="50" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1673084.jpg" title="Corazón Traicionado - S01:E50" userState="0"><Image alt="Corazón Traicionado - S01:E50" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E50" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1673084.jpg"/><Image alt="Corazón Traicionado - S01:E50" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1673084.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1774853581" duration="3133000" endsAt="1774856714" id="69c133d85a85056019e4d715" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774883193" duration="3133000" endsAt="1774886326" id="69c133d85a85056019e4d71f" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774913712" duration="3134000" endsAt="1774916846" id="69c133d85a85056019e4d729" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69c133d65a85056019e4d6f1" key="/library/metadata/69c133d65a85056019e4d6f1" ratingKey="69c133d65a85056019e4d6f1" summary="Ante la insistencia de Sergio por apresurar la boda, Victoria trata de convencerlo de esperar un tiempo, pero no tiene motivos para no adelantar su boda, así que Victoria acepta casarse en una semana. A escondidas, Nicolás escucha cuando Florencia le advierte a Fernanda so miedo de perder a su esposo, porque si no fuera por la trampa que ambas fraguaron ya Nicolás la hubiese abandonado; un indignado Nicolás las enfrenta, pues no puede creer que su tía y su esposa lo hayan engańado para impedir su matrimonio con Victoria. A solas con su esposa, Nicolás entiende como Florencia lo vio sufrir por Victoria y aún así lo traicionó, así que Nicolás decide separarse de ella; Florencia no quiere ser condenada por un error, pero Nicolás admite que su error es haberse casado con ella. El miedo embarga a Victoria por su nueva vida junto a su futuro esposo, Sergio, pero Adelaida apoya la decisión de su hija; En un nuevo día, cuando Victoria le afirma a su madre que siente una necesidad de huir de sus sentimientos por Nicolás, Adelaida se le impone, pues no apoyará a su hija en la decisión de casarse, pues le aconseja hablar con Sergio y cancelar el matrimonio." type="episode" contentRating="NONADULT" duration="2566000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="114" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E114" userState="0"><Image alt="S01:E114" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E114" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E114" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1774859636" duration="2566000" endsAt="1774862202" id="69c133d85a85056019e4d717" onAir="0" premiere="0" videoResolution="720" origin="livetv"/><Media beginsAt="1774889248" duration="3071000" endsAt="1774892319" id="69c133d85a85056019e4d721" onAir="0" premiere="0" videoResolution="720" origin="livetv"/></Video><Video guid="plex://episode/69c133d65a85056019e4d6f3" key="/library/metadata/69c133d65a85056019e4d6f3" ratingKey="69c133d65a85056019e4d6f3" summary="Aunque Victoria quiere que Hilario se olvide de Nicolás de una vez; el seńor Guanipa está seguro de que llegará el día en que ella misma le pedirá que le cobre a Del Casal lo que le hizo, pues no va a poder vivir con tanta rabia. Fernanda se molesta al saber que Nicolás estuvo en Cantarrana. Nicolás comenta con Florencia que está seguro de que Fernanda se las ingenió para mandar desde su computadora un montón de cartas que le hicieron creer a Victoria que él la ha estado engańando; el joven está convencido de que la joven Zapata no es quien está ayudando a su tía y duda que haya sido Hilario quien contratara a alguien que lo hiciera como ella sugiere. Nicolás le cuenta a Fernanda de los papeles que encontró en Los Samanes; el joven asevera que, aunque Victoria los destruyó, él recuerda varios nombres y piensa que con eso, y lo que Rosendo le contara a Florencia, pueden empezar a buscar pruebas en contra de Guanipa." type="episode" contentRating="NONADULT" duration="3048000" grandparentArt="https://cdn-images.watch4.com/1080/3/1766385.jpg" grandparentGuid="plex://show/67a0b759cb3d68c83b1e7d4f" grandparentKey="/library/metadata/67a0b759cb3d68c83b1e7d4f" grandparentRatingKey="67a0b759cb3d68c83b1e7d4f" grandparentThumb="https://cdn-images.watch4.com/1920/2/1766385.jpg" grandparentTitle="La Trepadora" grandparentType="show" index="32" parentIndex="1" requiresConsent="1" skipParent="1" thumb="https://cdn-images.watch4.com/1080/3/1766385.jpg" title="S01:E032" userState="0"><Image alt="S01:E032" type="coverArt" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Image alt="S01:E032" type="coverPoster" url="https://cdn-images.watch4.com/1920/2/1766385.jpg"/><Image alt="S01:E032" type="snapshot" url="https://cdn-images.watch4.com/1080/3/1766385.jpg"/><Genre filter="genre=6006cc18610ee2002c74f2fe" id="6006cc18610ee2002c74f2fe" key="/library/sections/home/all?genre=6006cc18610ee2002c74f2fe" ratingKey="genre_6006cc18610ee2002c74f2fe" slug="drama" tag="Drama" type="directory" context="tag.genre"/><Media beginsAt="1774877105" dura